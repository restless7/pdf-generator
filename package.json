{
  "name": "@planmaestro/pdf-generator",
  "version": "1.0.0",
  "description": "Professional PDF generation service for PlanMaestro ecosystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); if(fs.existsSync('templates')) fs.cpSync('templates', 'dist/templates', {recursive: true, force: true})\"",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "start": "node dist/server.js",
    "start:dev": "ts-node src/server.ts",
    "build:server": "npm run build",
    "railway:build": "npm run build",
    "railway:start": "./start-railway.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@types/showdown": "^2.0.6",
    "@types/uuid": "^10.0.0",
    "bullmq": "^5.76.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "encodeurl": "^2.0.0",
    "escape-html": "^1.0.3",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.1",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.3",
    "pug": "^3.0.3",
    "showdown": "^2.1.0",
    "uuid": "^11.1.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/pug": "^2.0.10",
    "jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
