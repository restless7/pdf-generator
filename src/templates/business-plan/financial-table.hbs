<!-- Financial Table Partial -->
<div class="financial-table-container">
    {{#if title}}
    <h3 class="table-title">{{title}}</h3>
    {{/if}}
    
    <table class="financial-table">
        {{#if headers}}
        <thead>
            <tr>
                {{#each headers}}
                <th>{{this}}</th>
                {{/each}}
            </tr>
        </thead>
        {{/if}}
        
        <tbody>
            {{#each rows}}
            <tr>
                {{#each this}}
                <td>{{this}}</td>
                {{/each}}
            </tr>
            {{/each}}
        </tbody>
    </table>
    
    {{#if notes}}
    <div class="table-notes">
        <h4>Notas:</h4>
        <ul>
            {{#each notes}}
            <li>{{this}}</li>
            {{/each}}
        </ul>
    </div>
    {{/if}}
</div>
