<!-- Footer Section -->
<div class="document-footer">
    <div class="footer-content">
        <div class="footer-brand">
            <div class="brand-name">PlanMaestro</div>
            <div class="brand-tagline">Inteligencia Artificial aplicada a la consultoría empresarial</div>
        </div>
        
        <div class="footer-details">
            <p><strong>{{businessName}}</strong> - Plan de Negocio</p>
            <p>Documento generado el {{currentDate}}</p>
            {{#if confidential}}
            <p class="confidential-notice">CONFIDENCIAL - Para uso interno únicamente</p>
            {{/if}}
        </div>
        
        <div class="footer-meta">
            <p>Página {{{pageNumber}}} de {{{totalPages}}}</p>
            <p>Versión {{#if version}}{{version}}{{else}}1.0{{/if}}</p>
        </div>
    </div>
</div>
