<!-- Header Section -->
<div class="document-header">
    <div class="header-brand">
        {{#if logo}}
        <img src="{{logo}}" alt="{{businessName}} Logo" class="company-logo">
        {{/if}}
        <div class="header-text">
            <h1 class="document-title">Plan de Negocio</h1>
            <h2 class="business-name">{{businessName}}</h2>
        </div>
    </div>
    <div class="header-meta">
        <p class="generation-date">Generado el {{currentDate}}</p>
        <p class="document-version">Versión {{#if version}}{{version}}{{else}}1.0{{/if}}</p>
    </div>
</div>
