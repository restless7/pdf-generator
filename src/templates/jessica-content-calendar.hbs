      </div>
    </div>

    <footer>
      <div>APEX AI Solutions — Bucaramanga, Colombia • support@apexaisolutions.dev</div>
      <div class="muted">Documento confidencial · Validez: 30 días · Ref: APEX-2026-0330-FUJ</div>
    </footer>
  </div>
