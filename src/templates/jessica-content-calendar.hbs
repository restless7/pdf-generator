<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Propuesta - Fujiyama & APEX AI Solutions</title>
  <style>
    /* --- RESET / PAGE --- */
    :root{
      --bg:#0b1220;
      --card:#ffffff;
      --muted:#6b7280;
      --white:#ffffff;
      --emerald:#10b981;
      --accent:#06b6d4;
      --paper:#ffffff;
      --border:#e5e7eb;
      --text:#1f2937;
    }
    html,body{height:100%;margin:0;font-family:'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background:var(--paper); color:var(--text); line-height:1.5;}
    .page{max-width:210mm;margin:0 auto;padding:15mm;background:var(--paper);}
    header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;}
    .header-content{flex:1;}
    .logo{width:120px;height:auto;}
    h1{margin:0;font-size:24px;color:var(--text);font-weight:600;}
    .subtitle{margin:6px 0 0;color:var(--muted);font-size:14px;font-weight:400;}
    .meta{text-align:right;font-size:12px;color:var(--muted);margin-top:4px;}
    .meta strong{color:var(--text);font-weight:500;}
    hr.sep{border:none;border-top:1px solid var(--border);margin:20px 0;}
    .section{margin-bottom:20px;}
    .lead{color:var(--text);font-size:14px;line-height:1.6;}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
    .card{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:16px;}
    .card h3{margin:0 0 8px;font-size:14px;color:var(--text);font-weight:600;}
    .card p{margin:0;color:var(--muted);font-size:13px;line-height:1.4;}
    ul.clean{padding-left:20px;margin:12px 0;color:var(--muted);font-size:13px;}
    table.pricing{width:100%;border-collapse:collapse;margin-top:12px;}
    table.pricing thead th{background:#f9fafb;color:var(--text);padding:12px;text-align:left;border-bottom:2px solid var(--border);font-weight:600;font-size:13px;}
    table.pricing td{padding:12px;border-bottom:1px solid var(--border);color:var(--text);font-size:13px;}
    .muted{color:var(--muted);font-size:13px;}
    .badge{display:inline-block;padding:4px 8px;border-radius:4px;background:#f0f9f4;color:#065f46;font-weight:500;font-size:11px;}
    .badge-blue{display:inline-block;padding:4px 8px;border-radius:4px;background:#eff6ff;color:#1d4ed8;font-weight:500;font-size:11px;}
    .cta{display:inline-block;margin-top:12px;padding:8px 16px;background:var(--emerald);color:white;border-radius:4px;text-decoration:none;font-weight:500;font-size:14px;}
    .two-cols{display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;}
    .small-note{font-size:11px;color:var(--muted);margin-top:8px;}
    .sig-blocks{display:flex;gap:20px;margin-top:32px;}
    .sig{flex:1;border-top:1px solid var(--border);padding-top:12px;text-align:center;font-size:12px;color:var(--text);}
    footer{margin-top:32px;border-top:1px solid var(--border);padding-top:16px;font-size:11px;color:var(--muted);display:flex;justify-content:space-between;align-items:center;}
    h2{color:var(--text);font-size:18px;margin:0 0 12px;font-weight:600;}
    h3{color:var(--text);font-weight:600;}
    .highlight-box{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;padding:16px;margin-top:12px;}
    .highlight-box h3{color:#065f46;margin:0 0 8px;font-size:14px;}
    .discount-badge{display:inline-block;padding:4px 10px;border-radius:12px;background:#065f46;color:white;font-weight:600;font-size:12px;margin-left:6px;}
    .price-tag{font-size:18px;font-weight:700;color:var(--text);}
    .price-original{text-decoration:line-through;color:var(--muted);font-size:14px;margin-right:8px;}
    /* print friendly */
    @media print{
      body{background:white;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
      .page{box-shadow:none;border:none;margin:0;border-radius:0;padding:10mm;}
      .section { page-break-before: always; }
      .section:first-of-type { page-break-before: auto; }
      hr.sep { display: none; }
    }
