<footer class="proposal-footer" style="
    margin-top: 3rem;
    padding: 2rem;
    background: var(--gray-50);
    border-top: 2px solid var(--emerald-light);
    border-radius: var(--radius-lg);
    text-align: center;
">
    <div style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 2rem; margin-bottom: 1rem;">
        <div style="text-align: left; font-size: 0.8rem; color: var(--gray-500);">
            <div><strong>{{companyName}}</strong></div>
            {{#if contactInfo.address}}<div>{{contactInfo.address}}</div>{{/if}}
            {{#if contactInfo.phone}}<div>Tel: {{contactInfo.phone}}</div>{{/if}}
        </div>
        
        <div style="
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-emerald), var(--primary-emerald-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 700;
            font-size: 1.25rem;
        ">
            {{substring companyName 0 2}}
        </div>
        
        <div style="text-align: right; font-size: 0.8rem; color: var(--gray-500);">
            {{#if contactInfo.email}}<div>{{contactInfo.email}}</div>{{/if}}
            {{#if contactInfo.website}}<div>{{contactInfo.website}}</div>{{/if}}
            <div style="margin-top: 0.5rem; font-weight: 600; color: var(--primary-emerald);">
                Propuesta válida hasta: {{formatDate validUntil}}
            </div>
        </div>
    </div>
    
    <div style="border-top: 1px solid var(--gray-200); padding-top: 1rem; font-size: 0.75rem; color: var(--gray-400);">
        Propuesta generada el {{formatDate currentDate}} • Documento confidencial
        {{#if metadata.branding.companyName}}
        <br>Generado con {{metadata.branding.companyName}} PDF Generator v2.0
        {{/if}}
    </div>
</footer>
