<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{proposalTitle}} - Propuesta Comercial</title>
    <style>
        /* Modern Professional Design System - Proposal Template */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        :root {
            --primary-emerald: #10B981;
            --primary-emerald-dark: #059669;
            --emerald-light: #D1FAE5;
            --emerald-50: #ECFDF5;
            --gray-900: #111827;
            --gray-800: #1F2937;
            --gray-700: #374151;
            --gray-600: #4B5563;
            --gray-500: #6B7280;
            --gray-400: #9CA3AF;
            --gray-300: #D1D5DB;
            --gray-100: #F3F4F6;
            --gray-50: #F9FAFB;
            --white: #FFFFFF;
            --accent-blue: #3B82F6;
            --accent-purple: #8B5CF6;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --radius-md: 8px;
            --radius-lg: 12px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.7;
            color: var(--gray-700);
            background: var(--white);
            font-size: 14px;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        .container {
            max-width: 210mm;
            margin: 0 auto;
            padding: 0;
        }
        
        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            color: var(--gray-900);
            font-weight: 600;
            line-height: 1.25;
            margin-bottom: 1rem;
        }
        
        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-emerald), var(--primary-emerald-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-align: center;
            margin-bottom: 1.5rem;
        }
        
        h2 {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--gray-900);
            margin-top: 3rem;
            margin-bottom: 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--emerald-light);
            position: relative;
        }
        
        h2::before {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 60px;
            height: 2px;
            background: linear-gradient(90deg, var(--primary-emerald), var(--primary-emerald-dark));
        }
        
        h3 {
            font-size: 1.375rem;
            font-weight: 600;
            color: var(--gray-800);
            margin-top: 2rem;
            margin-bottom: 1rem;
        }
        
        h4 {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--gray-700);
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
        }
        
        p {
            margin-bottom: 1.25rem;
            color: var(--gray-600);
            text-align: justify;
        }
        
        /* Lists */
        ul, ol {
            margin-bottom: 1.25rem;
            padding-left: 1.5rem;
        }
        
        li {
            margin-bottom: 0.5rem;
            color: var(--gray-600);
        }
        
        ul li::marker {
            color: var(--primary-emerald);
        }
        
        strong {
            font-weight: 600;
            color: var(--gray-800);
        }
        
        /* Page breaks */
        .page-break {
            page-break-before: always;
        }
        
        .page-break-avoid {
            page-break-inside: avoid;
        }
        
        /* Cover page */
        .cover-page {
            height: 297mm;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: linear-gradient(135deg, var(--emerald-50) 0%, var(--white) 100%);
            position: relative;
            overflow: hidden;
            padding: 3rem;
        }
        
        .cover-page::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, transparent 70%);
            animation: pulse 8s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .cover-content {
            position: relative;
            z-index: 10;
            max-width: 600px;
            padding: 3rem;
        }
        
        .cover-title {
            font-size: 3rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-emerald), var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }
        
        .cover-subtitle {
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--gray-600);
            margin-bottom: 2rem;
        }
        
        .cover-details {
            background: var(--white);
            padding: 2rem;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--gray-200);
            margin: 2rem 0;
        }
        
        .cover-detail-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--gray-100);
        }
        
        .cover-detail-item:last-child {
            border-bottom: none;
        }
        
        .cover-detail-label {
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.9rem;
        }
        
        .cover-detail-value {
            color: var(--gray-800);
            font-weight: 500;
        }
        
        /* Content Sections */
        .content-section {
            background: var(--white);
            padding: 2rem;
            margin: 2rem 0;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-100);
        }
        
        /* Highlight boxes */
        .highlight-box {
            background: linear-gradient(135deg, var(--emerald-50) 0%, rgba(16, 185, 129, 0.05) 100%);
            border-left: 4px solid var(--primary-emerald);
            padding: 1.5rem;
            margin: 1.5rem 0;
            border-radius: 0 var(--radius-md) var(--radius-md) 0;
        }
        
        .highlight-box h4 {
            color: var(--primary-emerald-dark);
            margin-top: 0;
        }
        
        /* Service cards */
        .service-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }
        
        .service-card {
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            box-shadow: var(--shadow-sm);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .service-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        
        .service-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--primary-emerald), var(--accent-blue));
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            color: var(--white);
            font-weight: 600;
            font-size: 1.25rem;
        }
        
        .service-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 0.5rem;
        }
        
        .service-description {
            color: var(--gray-600);
            font-size: 0.9rem;
            line-height: 1.6;
            margin-bottom: 1rem;
        }
        
        .service-price {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-emerald);
            margin-bottom: 0.5rem;
        }
        
        .service-features {
            list-style: none;
            padding: 0;
        }
        
        .service-features li {
            color: var(--gray-600);
            font-size: 0.85rem;
            margin-bottom: 0.25rem;
            position: relative;
            padding-left: 1rem;
        }
        
        .service-features li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--primary-emerald);
            font-weight: 600;
        }
        
        /* Timeline */
        .timeline {
            position: relative;
            padding-left: 2rem;
            margin: 2rem 0;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 0.75rem;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, var(--primary-emerald), var(--emerald-light));
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 2rem;
            background: var(--white);
            border-radius: var(--radius-md);
            padding: 1.5rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-100);
        }
        
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.5rem;
            top: 1.5rem;
            width: 12px;
            height: 12px;
            background: var(--primary-emerald);
            border-radius: 50%;
            border: 3px solid var(--white);
            box-shadow: 0 0 0 3px var(--emerald-light);
        }
        
        .timeline-phase {
            font-weight: 600;
            color: var(--primary-emerald);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }
        
        .timeline-title {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 0.5rem;
        }
        
        .timeline-duration {
            font-size: 0.85rem;
            color: var(--gray-500);
            font-style: italic;
            margin-bottom: 0.75rem;
        }
        
        /* Pricing table */
        .pricing-table {
            width: 100%;
            border-collapse: collapse;
            margin: 2rem 0;
            background: var(--white);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }
        
        .pricing-table th {
            background: linear-gradient(135deg, var(--primary-emerald), var(--primary-emerald-dark));
            color: var(--white);
            font-weight: 600;
            padding: 1rem;
            text-align: left;
            font-size: 0.9rem;
        }
        
        .pricing-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-100);
            color: var(--gray-600);
        }
        
        .pricing-table tr:last-child td {
            border-bottom: none;
        }
        
        .pricing-table tr:nth-child(even) {
            background: var(--gray-50);
        }
        
        .price-amount {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary-emerald);
        }
        
        /* Footer */
        .footer {
            margin-top: 4rem;
            padding: 2rem;
            background: var(--gray-50);
            border-top: 1px solid var(--gray-200);
            text-align: center;
            color: var(--gray-500);
            font-size: 0.85rem;
        }
        
        .footer-logo {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary-emerald);
            margin-bottom: 0.5rem;
        }
        
        /* Print optimizations */
        @media print {
            body {
                font-size: 12pt;
            }
            
            h1 {
                font-size: 24pt;
            }
            
            h2 {
                font-size: 18pt;
            }
            
            h3 {
                font-size: 14pt;
            }
            
            .page-break {
                page-break-before: always;
            }
            
            .page-break-avoid {
                page-break-inside: avoid;
            }
            
            .service-card,
            .timeline-item {
                page-break-inside: avoid;
            }
            
            .cover-page {
                height: 100vh;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Cover Page -->
        <div class="cover-page page-break-avoid">
            <div class="cover-content">
                <div class="cover-title">{{proposalTitle}}</div>
                <div class="cover-subtitle">Propuesta Comercial Profesional</div>
                
                <div class="cover-details">
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Cliente:</span>
                        <span class="cover-detail-value">{{clientName}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Proveedor:</span>
                        <span class="cover-detail-value">{{companyName}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Fecha de Propuesta:</span>
                        <span class="cover-detail-value">{{formatDate proposalDate}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Válida hasta:</span>
                        <span class="cover-detail-value">{{formatDate validUntil}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Presupuesto Total:</span>
                        <span class="cover-detail-value price-amount">{{formatCurrency totalAmount}} {{currency}}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Executive Summary -->
        <div class="page-break">
            <h2>Resumen Ejecutivo</h2>
            <div class="content-section">
                <p>{{formatContent executiveSummary}}</p>
                
                {{#if highlights}}
                <div class="highlight-box">
                    <h4>Puntos Destacados</h4>
                    <p>{{formatContent highlights}}</p>
                </div>
                {{/if}}
            </div>
        </div>

        <!-- Services/Solutions Section -->
        {{#if services}}
        <h2>Servicios Propuestos</h2>
        <div class="service-grid">
            {{#each services}}
            <div class="service-card page-break-avoid">
                <div class="service-icon">{{@index}}</div>
                <div class="service-title">{{title}}</div>
                <div class="service-description">{{formatContent description}}</div>
                {{#if price}}
                <div class="service-price">{{formatCurrency price}} {{../currency}}</div>
                {{/if}}
                {{#if features}}
                <ul class="service-features">
                    {{#each features}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}
            </div>
            {{/each}}
        </div>
        {{/if}}

        <!-- Methodology/Approach -->
        {{#if methodology}}
        <div class="page-break">
            <h2>Metodología y Enfoque</h2>
            <div class="content-section">
                <p>{{formatContent methodology}}</p>
            </div>
        </div>
        {{/if}}

        <!-- Timeline -->
        {{#if timeline}}
        <h2>Cronograma de Trabajo</h2>
        <div class="timeline">
            {{#each timeline}}
            <div class="timeline-item">
                <div class="timeline-phase">Fase {{add @index 1}}</div>
                <div class="timeline-title">{{title}}</div>
                <div class="timeline-duration">{{duration}}</div>
                <p>{{formatContent description}}</p>
                {{#if deliverables}}
                <h4>Entregables:</h4>
                <ul>
                    {{#each deliverables}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}
            </div>
            {{/each}}
        </div>
        {{/if}}

        <!-- Pricing -->
        {{#if pricingBreakdown}}
        <div class="page-break">
            <h2>Detalle de Precios</h2>
            <table class="pricing-table">
                <thead>
                    <tr>
                        <th>Concepto</th>
                        <th>Descripción</th>
                        <th>Cantidad</th>
                        <th>Precio Unitario</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each pricingBreakdown}}
                    <tr>
                        <td><strong>{{concept}}</strong></td>
                        <td>{{description}}</td>
                        <td>{{quantity}}</td>
                        <td>{{formatCurrency unitPrice}} {{../currency}}</td>
                        <td class="price-amount">{{formatCurrency subtotal}} {{../currency}}</td>
                    </tr>
                    {{/each}}
                    <tr style="background: var(--emerald-50); font-weight: 600;">
                        <td colspan="4"><strong>TOTAL</strong></td>
                        <td class="price-amount" style="font-size: 1.5rem;">{{formatCurrency totalAmount}} {{currency}}</td>
                    </tr>
                </tbody>
            </table>
        </div>
        {{/if}}

        <!-- Terms and Conditions -->
        {{#if termsAndConditions}}
        <h2>Términos y Condiciones</h2>
        <div class="content-section">
            {{#each termsAndConditions}}
            <h4>{{title}}</h4>
            <p>{{formatContent content}}</p>
            {{/each}}
        </div>
        {{/if}}

        <!-- Next Steps -->
        {{#if nextSteps}}
        <h2>Próximos Pasos</h2>
        <div class="content-section">
            <p>{{formatContent nextSteps}}</p>
        </div>
        {{/if}}

        <!-- Contact Information -->
        <div class="page-break">
            <h2>Información de Contacto</h2>
            <div class="content-section">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                    <div>
                        <h4>{{companyName}}</h4>
                        {{#if contactInfo}}
                        <p>
                            {{#if contactInfo.address}}{{contactInfo.address}}<br>{{/if}}
                            {{#if contactInfo.phone}}Tel: {{contactInfo.phone}}<br>{{/if}}
                            {{#if contactInfo.email}}Email: {{contactInfo.email}}<br>{{/if}}
                            {{#if contactInfo.website}}Web: {{contactInfo.website}}{{/if}}
                        </p>
                        {{/if}}
                    </div>
                    <div>
                        <h4>Responsable del Proyecto</h4>
                        {{#if projectManager}}
                        <p>
                            <strong>{{projectManager.name}}</strong><br>
                            {{projectManager.title}}<br>
                            {{#if projectManager.phone}}Tel: {{projectManager.phone}}<br>{{/if}}
                            {{#if projectManager.email}}Email: {{projectManager.email}}{{/if}}
                        </p>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <div class="footer-logo">{{companyName}}</div>
            <p>Propuesta generada el {{formatDate currentDate}} • Documento confidencial</p>
            {{#if metadata.branding.companyName}}
            <p style="margin-top: 1rem; font-size: 0.75rem; color: var(--gray-400);">
                Generado con {{metadata.branding.companyName}} PDF Generator
            </p>
            {{/if}}
        </div>
    </div>
</body>
</html>
