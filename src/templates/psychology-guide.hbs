<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - {{subtitle}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Open+Sans:wght@400;600&display=swap');
    :root {
      --primary: #2563eb; /* blue */
      --primary-dark: #1e40af;
      --accent: #10b981; /* green */
      --muted: #6b7280; /* gray-500 */
      --text: #374151;  /* gray-700 */
      --bg: #ffffff;
      --soft: #f3f4f6;  /* gray-100 */
      --border: #e5e7eb; /* gray-200 */
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Open Sans', system-ui, -apple-system, Segoe UI, Roboto, sans-serif; color: var(--text); background: var(--bg); line-height: 1.7; font-size: 14px; }
    h1,h2,h3,h4 { font-family: 'Montserrat', sans-serif; color: #111827; }
    .container { max-width: 210mm; margin: 0 auto; }

    /* Cover */
    .cover { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 48px; background: linear-gradient(135deg, #ecfeff 0%, #f0fdf4 100%); position: relative; page-break-after: always; }
    .cover-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 40px; max-width: 620px; box-shadow: 0 10px 25px rgba(0,0,0,0.07); text-align: center; }
    .title { font-size: 38px; font-weight: 700; color: var(--primary-dark); margin-bottom: 10px; letter-spacing: -0.5px; line-height: 1.2; }
    .subtitle { font-size: 18px; color: var(--muted); margin-bottom: 20px; line-height: 1.3; }
    .author { font-weight: 600; color: var(--primary); margin-top: 8px; line-height: 1.4; }
    .author-cred { color: var(--muted); font-size: 13px; line-height: 1.4; }
    .illustration { margin: 20px 0; padding: 16px; border: 1px dashed var(--border); border-radius: 12px; color: var(--muted); font-size: 12px; background: #fafafa; line-height: 1.4; }
    .brand { margin-top: 16px; color: var(--muted); font-size: 12px; line-height: 1.4; }

    /* Page */
    .page { padding: 30px 40px; page-break-before: always; page-break-inside: avoid; min-height: calc(100vh - 60px); }
    .section { margin-bottom: 20px; }
    .section-header { border-bottom: 2px solid var(--border); padding-bottom: 8px; margin-bottom: 12px; }
    .section h2 { font-size: 22px; color: var(--primary-dark); line-height: 1.3; margin-bottom: 16px; }
    p { margin-bottom: 12px; text-align: justify; line-height: 1.6; }
    ul { padding-left: 18px; margin: 10px 0 12px; }
    li { margin-bottom: 6px; line-height: 1.5; }

    .infobox { background: #f0f9ff; border-left: 4px solid var(--primary); padding: 12px 14px; border-radius: 8px; margin: 12px 0; }
    .highlight { background: #ecfdf5; border-left: 4px solid var(--accent); padding: 12px 14px; border-radius: 8px; margin: 12px 0; }
    .quote { font-style: italic; border-left: 4px solid var(--primary); padding-left: 12px; color: #1f2937; margin: 14px 0; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .card { border: 1px solid var(--border); border-radius: 10px; padding: 12px; background: #fff; }

    .callout { background: #f9fafb; border: 1px solid var(--border); border-radius: 12px; padding: 14px; }
    .badge { display: inline-block; background: var(--primary); color: #fff; border-radius: 999px; padding: 2px 10px; font-size: 11px; margin-right: 6px; }
    .script { background: #111827; color: #f9fafb; border-radius: 8px; padding: 10px 12px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 12px; margin: 6px 0; }

    .page-break { page-break-before: always; }

    @media print { body { font-size: 12px; } .page { padding: 28px 30px; } }
  </style>
</head>
<body>
  <div class="container">
    <!-- Cover -->
    <div class="cover">
      <div class="cover-card">
        <div class="title">{{title}}</div>
        <div class="subtitle">{{subtitle}}</div>
        <div class="illustration">{{cover.illustrationPlaceholder}}</div>
        <div class="author">{{author}}</div>
        <div class="author-cred">{{authorCredentials}}</div>
        <div class="brand">Generado con APEX PDF Generator • {{generationDate}}</div>
      </div>
    </div>

    <!-- Introduction -->
    <div class="page page-break">
      <div class="section">
        <div class="section-header"><h2>{{introduction.title}}</h2></div>
        <p>{{introduction.content}}</p>
        <div class="illustration">{{introduction.illustrationPlaceholder}}</div>
      </div>
    </div>

    <!-- Chapters -->
    {{#each chapters}}
    <div class="page page-break">
      <div class="section">
        <div class="section-header"><h2>Capítulo {{this.number}}: {{this.title}}</h2></div>
        <p>{{this.content}}</p>
        {{#if this.keyPoints}}
          <div class="highlight">
            <strong>Puntos clave:</strong>
            <ul>
              {{#each this.keyPoints}}<li>{{this}}</li>{{/each}}
            </ul>
          </div>
        {{/if}}
        {{#if this.types}}
          <div class="grid-2">
            {{#each this.types}}
              <div class="card">
                <div><span class="badge">{{this.type}}</span></div>
                <p style="margin-top:6px;">{{this.description}}</p>
                {{#if this.examples}}
                  <ul>
                    {{#each this.examples}}<li>{{this}}</li>{{/each}}
                  </ul>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{/if}}
        {{#if this.steps}}
          <div class="infobox">
            <strong>Pasos prácticos:</strong>
            <ol style="margin:8px 0 0 18px;">
              {{#each this.steps}}
                <li><strong>{{this.step}}. {{this.title}}:</strong> {{this.description}} <em>{{this.action}}</em></li>
              {{/each}}
            </ol>
          </div>
        {{/if}}
        {{#if this.scripts}}
          <div class="section">
            <strong>Frases asertivas (usa y adapta):</strong>
            {{#each this.scripts}}<div class="script">{{this}}</div>{{/each}}
          </div>
        {{/if}}
        {{#if this.exercise}}
          <div class="callout">
            <strong>{{this.exercise.title}}</strong>
            <p>{{this.exercise.instructions}}</p>
            {{#if this.exercise.items}}
              <ul>
                {{#each this.exercise.items}}<li>{{this}}</li>{{/each}}
              </ul>
            {{/if}}
          </div>
        {{/if}}
        {{#if this.exercises}}
          <div class="section">
            {{#each this.exercises}}
              <div class="card" style="margin-bottom:10px;">
                <strong>{{this.title}}</strong>
                <p>{{this.instructions}}</p>
                {{#if this.questions}}
                  <ul>
                    {{#each this.questions}}<li>{{this}}</li>{{/each}}
                  </ul>
                {{/if}}
                {{#if this.steps}}
                  <ol style="margin-left:18px;">
                    {{#each this.steps}}<li>{{this}}</li>{{/each}}
                  </ol>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{/if}}
        {{#if this.bonusContent}}
          <div class="infobox">
            <strong>{{this.bonusContent.title}}</strong>
            <p>{{this.bonusContent.description}}</p>
            <ul>
              {{#each this.bonusContent.items}}<li>{{this}}</li>{{/each}}
            </ul>
          </div>
        {{/if}}
        {{#if this.strategies}}
          <div class="section">
            {{#each this.strategies}}
              <div class="card" style="margin-bottom:10px;">
                <strong>{{this.title}}</strong>
                <p>{{this.description}}</p>
                <p><em>Tip:</em> {{this.tip}}</p>
              </div>
            {{/each}}
          </div>
        {{/if}}
        {{#if this.quote}}<div class="quote">“{{this.quote}}”</div>{{/if}}
        {{#if this.illustrationPlaceholder}}<div class="illustration">{{this.illustrationPlaceholder}}</div>{{/if}}
      </div>
    </div>
    {{/each}}

    <!-- Conclusion -->
    <div class="page page-break">
      <div class="section">
        <div class="section-header"><h2>{{conclusion.title}}</h2></div>
        <p>{{conclusion.content}}</p>
        <div class="highlight"><strong>Practica ahora:</strong> {{conclusion.callToAction}}</div>
        <div class="illustration">{{conclusion.illustrationPlaceholder}}</div>
      </div>
    </div>

    <!-- About Author -->
    <div class="page page-break">
      <div class="section">
        <div class="section-header"><h2>{{authorBio.title}}</h2></div>
        <p><strong>{{authorBio.name}}</strong> — {{authorBio.credentials}}</p>
        <p>{{authorBio.description}}</p>
        <div class="grid-2">
          <div class="card">
            <strong>Especialidades</strong>
            <ul>
              {{#each authorBio.specialties}}<li>{{this}}</li>{{/each}}
            </ul>
          </div>
          <div class="card">
            <strong>Contacto</strong>
            <p>{{authorBio.contact}}</p>
            <div class="illustration">{{authorBio.illustrationPlaceholder}}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Next Steps -->
    <div class="page page-break">
      <div class="section">
        <div class="section-header"><h2>{{nextSteps.title}}</h2></div>
        <p>{{nextSteps.content}}</p>
        <div class="card">
          <strong>Próximos recursos</strong>
          <ul>
            {{#each nextSteps.futureResources}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
        <div class="infobox"><strong>CTA:</strong> {{nextSteps.cta}}</div>
      </div>
    </div>
  </div>
</body>
</html>