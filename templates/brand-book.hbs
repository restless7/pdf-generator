<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{brandName}} - Brand Book</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap');
    :root {
      /* Jessica's Muted Earthy Tones Palette */
      --peach-soft: #FFDCB2; /* Durazno suave - calidez, cercanía */
      --rose-melon: #FFB4A2; /* Rosa melón - empatía, dulzura */
      --rose-pale: #E5989B; /* Rosa palo - delicadeza, cuidado */
      --mauve-deep: #B5838D; /* Malva profundo - profundidad, equilibrio */
      --gray-violet: #6D6875; /* Gris-violeta - profesionalismo, seriedad */
      --white: #FFFFFF;
      --shadow: 0 4px 16px rgba(109, 104, 117, 0.1);
      --shadow-soft: 0 2px 8px rgba(109, 104, 117, 0.08);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Poppins', system-ui, -apple-system, sans-serif;
      color: var(--gray-violet);
      background: var(--white);
      line-height: 1.6;
      font-size: 14px;
    }
    
    .container { max-width: 210mm; margin: 0 auto; }
    
    h1, h2, h3 {
      font-family: 'Playfair Display', serif;
      color: var(--gray-violet);
      margin-bottom: 1rem;
    }
    
    /* Cover Page */
    .cover {
      height: 100vh;
      background: linear-gradient(135deg, var(--peach-soft) 0%, var(--rose-melon) 100%);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 3rem;
      page-break-after: always;
    }
    
    .cover-card {
      background: var(--white);
      border-radius: 20px;
      padding: 3rem;
      box-shadow: var(--shadow);
      max-width: 600px;
      width: 100%;
    }
    
    .brand-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--gray-violet);
      margin-bottom: 0.5rem;
      line-height: 1.2;
    }
    
    .tagline {
      font-size: 1.1rem;
      color: var(--mauve-deep);
      margin-bottom: 2rem;
      font-style: italic;
    }
    
    .version-info {
      background: var(--rose-pale);
      color: var(--white);
      padding: 0.5rem 1.5rem;
      border-radius: 25px;
      display: inline-block;
      font-weight: 500;
      font-size: 0.9rem;
    }
    
    .date {
      margin-top: 1rem;
      color: var(--mauve-deep);
      font-size: 0.9rem;
    }
    
    /* Page Layout */
    .page {
      padding: 2.5rem 3rem;
      min-height: calc(100vh - 5rem);
      page-break-before: always;
      page-break-inside: avoid;
    }
    
    .section {
      margin-bottom: 2.5rem;
    }
    
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      color: var(--gray-violet);
      margin-bottom: 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--rose-pale);
    }
    
    .subsection-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--mauve-deep);
      margin: 1.5rem 0 1rem 0;
    }
    
    p {
      margin-bottom: 1rem;
      line-height: 1.7;
      text-align: justify;
    }
    
    /* Color Palette Display */
    .color-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
      margin: 1.5rem 0;
    }
    
    .color-card {
      text-align: center;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: var(--shadow-soft);
    }
    
    .color-swatch {
      height: 80px;
      width: 100%;
    }
    
    .color-info {
      padding: 1rem;
      background: var(--white);
    }
    
    .color-name {
      font-weight: 600;
      color: var(--gray-violet);
      font-size: 0.9rem;
      margin-bottom: 0.3rem;
    }
    
    .color-hex {
      font-family: monospace;
      font-size: 0.8rem;
      color: var(--mauve-deep);
      margin-bottom: 0.3rem;
    }
    
    .color-usage {
      font-size: 0.75rem;
      color: var(--mauve-deep);
      font-style: italic;
    }
    
    /* Typography Showcase */
    .typo-example {
      background: linear-gradient(135deg, var(--peach-soft), var(--white));
      padding: 1.5rem;
      border-radius: 12px;
      margin: 1rem 0;
      border-left: 4px solid var(--rose-pale);
    }
    
    .typo-primary {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      color: var(--gray-violet);
      margin-bottom: 0.5rem;
    }
    
    .typo-secondary {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      color: var(--mauve-deep);
    }
    
    /* Visual Examples Grid */
    .examples-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin: 1.5rem 0;
    }
    
    .example-card {
      background: var(--white);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: var(--shadow-soft);
      border: 1px solid var(--peach-soft);
    }
    
    .example-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: var(--gray-violet);
      margin-bottom: 0.8rem;
      font-weight: 600;
    }
    
    .example-description {
      font-size: 0.9rem;
      color: var(--mauve-deep);
      margin-bottom: 1rem;
    }
    
    .example-elements {
      list-style: none;
      padding: 0;
    }
    
    .example-elements li {
      font-size: 0.8rem;
      color: var(--gray-violet);
      padding: 0.2rem 0;
      padding-left: 1rem;
      position: relative;
    }
    
    .example-elements li::before {
      content: '•';
      color: var(--rose-pale);
      font-weight: bold;
      position: absolute;
      left: 0;
    }
    
    /* Sample Phrases */
    .phrase-box {
      background: var(--rose-melon);
      color: var(--white);
      padding: 1.2rem;
      border-radius: 12px;
      margin: 0.8rem 0;
      font-style: italic;
      text-align: center;
      box-shadow: var(--shadow-soft);
    }
    
    /* Vocabulary Grid */
    .vocab-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 0.8rem;
      margin: 1.5rem 0;
    }
    
    .vocab-item {
      background: var(--peach-soft);
      color: var(--gray-violet);
      padding: 0.8rem;
      border-radius: 8px;
      text-align: center;
      font-weight: 500;
      font-size: 0.9rem;
    }
    
    /* Style Comparison */
    .comparison {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin: 1.5rem 0;
    }
    
    .correct {
      background: linear-gradient(135deg, var(--peach-soft), var(--white));
      padding: 1.2rem;
      border-radius: 12px;
      border-left: 4px solid var(--rose-pale);
    }
    
    .incorrect {
      background: #f8f8f8;
      padding: 1.2rem;
      border-radius: 12px;
      border-left: 4px solid #ccc;
      opacity: 0.7;
    }
    
    .comparison-label {
      font-weight: 600;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
    }
    
    .correct .comparison-label {
      color: var(--rose-pale);
    }
    
    .incorrect .comparison-label {
      color: #666;
    }
    
    /* Image Prompts */
    .prompt-box {
      background: var(--white);
      border: 2px dashed var(--rose-pale);
      padding: 1.2rem;
      border-radius: 12px;
      margin: 1rem 0;
      font-family: monospace;
      font-size: 0.85rem;
      color: var(--mauve-deep);
      line-height: 1.5;
    }
    
    /* Lists */
    ul, ol {
      padding-left: 1.5rem;
      margin: 1rem 0;
    }
    
    li {
      margin-bottom: 0.5rem;
      line-height: 1.6;
    }
    
    /* Highlight Boxes */
    .highlight-box {
      background: linear-gradient(135deg, var(--rose-pale), var(--mauve-deep));
      color: var(--white);
      padding: 1.5rem;
      border-radius: 12px;
      margin: 1.5rem 0;
      text-align: center;
    }
    
    .highlight-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      margin-bottom: 0.8rem;
      font-weight: 600;
    }
    
    /* Footer */
    .footer {
      text-align: center;
      padding: 2rem;
      color: var(--mauve-deep);
      font-size: 0.85rem;
      border-top: 1px solid var(--peach-soft);
      margin-top: 2rem;
    }
    
    /* Print Optimization */
    @media print {
      body { font-size: 12px; }
      .page { padding: 2rem; min-height: auto; }
      .cover { height: auto; min-height: 100vh; }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Cover Page -->
    <div class="cover">
      <div class="cover-card">
        <h1 class="brand-title">{{brandName}}</h1>
        <p class="tagline">{{tagline}}</p>
        <div class="version-info">Brand Book v{{version}}</div>
        <div class="date">{{date}}</div>
      </div>
    </div>

    <!-- Brand Essence -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">🌸 Esencia de la Marca</h2>
        
        <h3 class="subsection-title">Propósito</h3>
        <p>{{brandEssence.purpose}}</p>
        
        <h3 class="subsection-title">Personalidad de Marca</h3>
        <p>{{brandEssence.personality}}</p>
        
        <h3 class="subsection-title">Promesa de Valor</h3>
        <p>{{brandEssence.promise}}</p>
      </div>
    </div>

    <!-- Color Palette -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">🎨 Paleta de Colores</h2>
        <h3 class="subsection-title">{{colorPalette.name}}</h3>
        <p>{{colorPalette.description}}</p>
        
        <div class="color-grid">
          {{#each colorPalette.colors}}
          <div class="color-card">
            <div class="color-swatch" style="background-color: {{this.hex}};"></div>
            <div class="color-info">
              <div class="color-name">{{this.name}}</div>
              <div class="color-hex">{{this.hex}}</div>
              <div class="color-usage">{{this.usage}}</div>
            </div>
          </div>
          {{/each}}
        </div>
        
        <h3 class="subsection-title">Uso Sugerido</h3>
        <ul>
          <li><strong>Fondos web/papelería:</strong> {{#each colorPalette.usage.backgrounds}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</li>
          <li><strong>Acentos y tipografía:</strong> {{#each colorPalette.usage.accents}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</li>
          <li><strong>Call to actions:</strong> {{colorPalette.usage.callToActions}}</li>
        </ul>
      </div>
    </div>

    <!-- Typography -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">✍️ Tipografía</h2>
        
        <div class="typo-example">
          <div class="typo-primary">{{typography.primary.name}}</div>
          <div class="typo-secondary">{{typography.primary.usage}} → {{typography.primary.description}}</div>
        </div>
        
        <div class="typo-example">
          <div class="typo-secondary" style="font-size: 1.2rem; font-weight: 500;">{{typography.secondary.name}}</div>
          <div class="typo-secondary">{{typography.secondary.usage}} → {{typography.secondary.description}}</div>
        </div>
        
        <p><strong>Jerarquía:</strong> {{typography.hierarchy}}</p>
      </div>
    </div>

    <!-- Photographic Style -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">📸 Estilo Fotográfico</h2>
        
        <ul>
          {{#each photographicStyle.characteristics}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        
        <p><strong>Ejemplo:</strong> {{photographicStyle.example}}</p>
      </div>
      
      <div class="section">
        <h2 class="section-title">🎨 Elementos Gráficos</h2>
        
        <p><strong>Ilustraciones:</strong> {{graphicElements.illustrations}}</p>
        <p><strong>Formas:</strong> {{graphicElements.shapes}}</p>
        <p><strong>Iconografía:</strong> {{graphicElements.icons}}</p>
      </div>
    </div>

    <!-- Voice and Tone -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">🗣️ Tono de Voz</h2>
        
        <p><strong>Personalidad verbal:</strong> {{voiceTone.personality}}</p>
        <p><strong>Estilo comunicativo:</strong> {{voiceTone.style}}</p>
        <p><strong>Lenguaje preferido:</strong> {{voiceTone.preferredLanguage}}</p>
        <p><strong>Lenguaje a evitar:</strong> {{voiceTone.avoidLanguage}}</p>
        <p><strong>Nivel de formalidad:</strong> {{voiceTone.formalityLevel}}</p>
      </div>
      
      <div class="section">
        <h3 class="subsection-title">Aplicación en Canales</h3>
        <ul>
          <li><strong>Redes sociales:</strong> {{channelApplications.socialMedia}}</li>
          <li><strong>Servicio al cliente:</strong> {{channelApplications.customerService}}</li>
          <li><strong>Publicidad:</strong> {{channelApplications.advertising}}</li>
          <li><strong>Contenido:</strong> {{channelApplications.content}}</li>
        </ul>
      </div>
    </div>

    <!-- Sample Phrases and Vocabulary -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">💬 Frases Modelo</h2>
        
        {{#each samplePhrases}}
        <div class="phrase-box">{{this}}</div>
        {{/each}}
      </div>
      
      <div class="section">
        <h3 class="subsection-title">Paleta Verbal</h3>
        <div class="vocab-grid">
          {{#each brandVocabulary}}
          <div class="vocab-item">{{this}}</div>
          {{/each}}
        </div>
      </div>
      
      <div class="section">
        <h3 class="subsection-title">Comparación de Estilo</h3>
        <div class="comparison">
          <div class="correct">
            <div class="comparison-label">✅ Correcto</div>
            <p>{{styleComparison.correct}}</p>
          </div>
          <div class="incorrect">
            <div class="comparison-label">❌ Incorrecto</div>
            <p>{{styleComparison.incorrect}}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Visual Examples -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">🎭 Ejemplos Visuales Aplicados</h2>
        
        <div class="examples-grid">
          <div class="example-card">
            <h4 class="example-title">{{visualExamples.socialMediaPost.title}}</h4>
            <p class="example-description">{{visualExamples.socialMediaPost.description}}</p>
            <ul class="example-elements">
              {{#each visualExamples.socialMediaPost.elements}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
          
          <div class="example-card">
            <h4 class="example-title">{{visualExamples.businessCard.title}}</h4>
            <p class="example-description">{{visualExamples.businessCard.description}}</p>
            <ul class="example-elements">
              {{#each visualExamples.businessCard.elements}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
          
          <div class="example-card">
            <h4 class="example-title">{{visualExamples.websiteCover.title}}</h4>
            <p class="example-description">{{visualExamples.websiteCover.description}}</p>
            <ul class="example-elements">
              {{#each visualExamples.websiteCover.elements}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Digital Product Example -->
    <div class="page">
      <div class="section">
        <h2 class="section-title">📱 Ejemplo de Producto Digital</h2>
        
        <h3 class="subsection-title">{{digitalProductExample.title}}</h3>
        <p><em>{{digitalProductExample.subtitle}}</em></p>
        
        <p><strong>Portada:</strong> {{digitalProductExample.coverDescription}}</p>
        <p><strong>Estilo de contenido:</strong> {{digitalProductExample.contentStyle}}</p>
      </div>
      
      <div class="section">
        <h3 class="subsection-title">🎨 Prompts de Imagen Optimizados</h3>
        
        {{#each imagePrompts}}
        <div class="prompt-box">{{this}}</div>
        {{/each}}
      </div>
    </div>

    <!-- Executive Summary -->
    <div class="page">
      <div class="highlight-box">
        <h2 class="highlight-title">📋 Resumen Ejecutivo</h2>
        <p>{{executiveSummary}}</p>
      </div>
      
      <div class="footer">
        <p><strong>{{brandName}} Brand Book</strong></p>
        <p>Generado el {{generationDate}} • APEX PDF Generator</p>
        <p>✨ Manual base de identidad visual + tono de voz</p>
      </div>
    </div>
  </div>
</body>
</html>