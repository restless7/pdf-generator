<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Factura {{invoiceNumber}} - {{companyName}}</title>
    <style>
        /* Modern Professional Design System - Invoice Template */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        :root {
            --primary-emerald: #dc2626;
            --primary-emerald-dark: #991b1b;
            --emerald-light: #fecaca;
            --emerald-50: #fef2f2;
            --gray-900: #111827;
            --gray-800: #1F2937;
            --gray-700: #374151;
            --gray-600: #4B5563;
            --gray-500: #6B7280;
            --gray-400: #9CA3AF;
            --gray-300: #D1D5DB;
            --gray-100: #F3F4F6;
            --gray-50: #F9FAFB;
            --white: #FFFFFF;
            --accent-blue: #3B82F6;
            --accent-red: #EF4444;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --radius-md: 8px;
            --radius-lg: 12px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: var(--gray-700);
            background: var(--white);
            font-size: 14px;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            padding: 20px;
        }
        
        .invoice-container {
            max-width: 210mm;
            margin: 0 auto;
            background: var(--white);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }
        
        /* Header */
        .invoice-header {
            background: linear-gradient(135deg, var(--primary-emerald) 0%, var(--primary-emerald-dark) 100%);
            color: var(--white);
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }
        
        .invoice-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 100%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        }
        
        .header-content {
            position: relative;
            z-index: 10;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 2rem;
            align-items: center;
        }
        
        .company-info h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--white);
        }
        
        .company-tagline {
            font-size: 1rem;
            opacity: 0.9;
            margin-bottom: 1rem;
        }
        
        .invoice-details {
            text-align: right;
        }
        
        .invoice-number {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--white);
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }
        
        .invoice-date {
            font-size: 0.9rem;
            opacity: 0.9;
        }
        
        /* Content */
        .invoice-content {
            padding: 2rem;
        }
        
        /* Client Section */
        .client-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            margin-bottom: 3rem;
            padding: 1.5rem;
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            border: 1px solid var(--gray-200);
        }
        
        .bill-to, .ship-to {
            position: relative;
        }
        
        .section-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--primary-emerald);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--emerald-light);
        }
        
        .client-info {
            color: var(--gray-700);
            line-height: 1.6;
        }
        
        .client-name {
            font-weight: 600;
            font-size: 1.125rem;
            color: var(--gray-900);
            margin-bottom: 0.5rem;
        }
        
        /* Invoice Status */
        .invoice-status {
            display: inline-block;
            padding: 0.5rem 1rem;
            border-radius: var(--radius-md);
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2rem;
        }
        
        .status-paid {
            background: var(--emerald-light);
            color: var(--primary-emerald-dark);
        }
        
        .status-pending {
            background: #FEF3C7;
            color: #D97706;
        }
        
        .status-overdue {
            background: #FECACA;
            color: var(--accent-red);
        }
        
        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 2rem;
            background: var(--white);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }
        
        .items-table th {
            background: linear-gradient(135deg, var(--gray-800) 0%, var(--gray-900) 100%);
            color: var(--white);
            font-weight: 600;
            padding: 1rem;
            text-align: left;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .items-table th:last-child,
        .items-table td:last-child {
            text-align: right;
        }
        
        .items-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-100);
            color: var(--gray-600);
            vertical-align: top;
        }
        
        .items-table tr:last-child td {
            border-bottom: none;
        }
        
        .items-table tr:nth-child(even) {
            background: var(--gray-50);
        }
        
        .item-description {
            font-weight: 500;
            color: var(--gray-800);
            margin-bottom: 0.25rem;
        }
        
        .item-details {
            font-size: 0.85rem;
            color: var(--gray-500);
            line-height: 1.4;
        }
        
        .item-quantity,
        .item-rate,
        .item-amount {
            font-weight: 500;
            color: var(--gray-700);
        }
        
        /* Totals Section */
        .totals-section {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 2rem;
            margin-top: 2rem;
        }
        
        .payment-info {
            padding: 1.5rem;
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            border: 1px solid var(--gray-200);
        }
        
        .payment-info h3 {
            color: var(--gray-800);
            margin-bottom: 1rem;
            font-size: 1rem;
            font-weight: 600;
        }
        
        .payment-details {
            font-size: 0.9rem;
            color: var(--gray-600);
            line-height: 1.6;
        }
        
        .totals-table {
            border-collapse: collapse;
            width: 100%;
        }
        
        .totals-table td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--gray-200);
            font-size: 0.9rem;
        }
        
        .totals-table td:first-child {
            font-weight: 500;
            color: var(--gray-700);
        }
        
        .totals-table td:last-child {
            text-align: right;
            font-weight: 600;
            color: var(--gray-800);
        }
        
        .total-row {
            background: var(--emerald-50);
            font-weight: 700 !important;
        }
        
        .total-row td {
            font-size: 1.25rem !important;
            color: var(--primary-emerald-dark) !important;
            border-bottom: none !important;
            padding: 1rem !important;
        }
        
        /* Notes Section */
        .notes-section {
            margin-top: 3rem;
            padding: 1.5rem;
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            border-left: 4px solid var(--primary-emerald);
            page-break-inside: avoid;
            break-inside: avoid;
        }
        
        .notes-section h3 {
            color: var(--gray-800);
            margin-bottom: 0.75rem;
            font-size: 1rem;
            font-weight: 600;
        }
        
        .notes-content {
            color: var(--gray-600);
            font-size: 0.9rem;
            line-height: 1.6;
        }
        
        /* Terms Section */
        .terms-section {
            margin-top: 2rem;
            padding: 1.5rem;
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-lg);
        }
        
        .terms-section h3 {
            color: var(--gray-800);
            margin-bottom: 1rem;
            font-size: 1rem;
            font-weight: 600;
        }
        
        .terms-list {
            list-style: none;
            padding: 0;
        }
        
        .terms-list li {
            padding: 0.5rem 0;
            color: var(--gray-600);
            font-size: 0.85rem;
            line-height: 1.5;
            position: relative;
            padding-left: 1.5rem;
        }
        
        .terms-list li::before {
            content: '•';
            position: absolute;
            left: 0;
            color: var(--primary-emerald);
            font-weight: 600;
        }
        
        /* Footer */
        .invoice-footer {
            margin-top: 3rem;
            padding: 1.5rem 2rem;
            background: var(--gray-800);
            color: var(--white);
            text-align: center;
            border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 2rem;
        }
        
        .footer-company {
            text-align: left;
            font-size: 0.85rem;
        }
        
        .footer-logo {
            width: 50px;
            height: 50px;
            background: var(--primary-emerald);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 700;
            font-size: 1.125rem;
        }
        
        .footer-contact {
            text-align: right;
            font-size: 0.85rem;
        }
        
        .footer-legal {
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--gray-600);
            font-size: 0.75rem;
            color: var(--gray-400);
        }
        
        /* Print optimizations */
        @media print {
            body {
                font-size: 12pt;
                padding: 0;
            }
            
            .invoice-container {
                box-shadow: none;
                border-radius: 0;
            }
            
            .invoice-header,
            .invoice-footer {
                border-radius: 0;
            }
        }
    </style>
</head>
<body>
    <div class="invoice-container">
        <!-- Header -->
        <div class="invoice-header">
            <div class="header-content">
                <div class="company-info">
                    <h1>{{companyName}}</h1>
                    <div class="company-tagline">{{companyTagline}}</div>
                    {{#if companyInfo.address}}
                    <div style="font-size: 0.9rem; opacity: 0.9; line-height: 1.5;">
                        {{companyInfo.address}}<br>
                        {{#if companyInfo.phone}}Tel: {{companyInfo.phone}}{{/if}}
                        {{#if companyInfo.email}} • {{companyInfo.email}}{{/if}}
                    </div>
                    {{/if}}
                </div>
                <div class="invoice-details">
                    <div class="invoice-number">{{invoiceNumber}}</div>
                    <div class="invoice-date">Fecha: {{invoiceDate}}</div>
                    {{#if dueDate}}
                    <div class="invoice-date">Vencimiento: {{dueDate}}</div>
                    {{/if}}
                </div>
            </div>
        </div>

        <!-- Content -->
        <div class="invoice-content">
            <!-- Status -->
            {{#if status}}
            <div class="invoice-status status-{{status}}">
                {{#eq status 'paid'}}Pagada{{/eq}}
                {{#eq status 'pending'}}Pendiente{{/eq}}
                {{#eq status 'overdue'}}Vencida{{/eq}}
            </div>
            {{/if}}

            <!-- Client Information -->
            <div class="client-section">
                <div class="bill-to">
                    <div class="section-title">Facturar a</div>
                    <div class="client-info">
                        <div class="client-name">{{billTo.name}}</div>
                        {{#if billTo.company}}<div>{{billTo.company}}</div>{{/if}}
                        {{#if billTo.address}}
                        <div>{{billTo.address}}</div>
                        {{/if}}
                        {{#if billTo.email}}<div>{{billTo.email}}</div>{{/if}}
                        {{#if billTo.phone}}<div>{{billTo.phone}}</div>{{/if}}
                        {{#if billTo.taxId}}<div>NIF/CIF: {{billTo.taxId}}</div>{{/if}}
                    </div>
                </div>
                {{#if shipTo}}
                <div class="ship-to">
                    <div class="section-title">Enviar a</div>
                    <div class="client-info">
                        <div class="client-name">{{shipTo.name}}</div>
                        {{#if shipTo.company}}<div>{{shipTo.company}}</div>{{/if}}
                        {{#if shipTo.address}}
                        <div>{{shipTo.address}}</div>
                        {{/if}}
                        {{#if shipTo.phone}}<div>{{shipTo.phone}}</div>{{/if}}
                    </div>
                </div>
                {{/if}}
            </div>

            <!-- Items Table -->
            <table class="items-table">
                <thead>
                    <tr>
                        <th style="width: 45%;">Descripción</th>
                        <th style="width: 10%;">Cant.</th>
                        <th style="width: 15%;">Precio Unit.</th>
                        {{#if showTax}}<th style="width: 10%;">IVA</th>{{/if}}
                        <th style="width: 20%;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                    <tr>
                        <td>
                            <div class="item-description">{{description}}</div>
                            {{#if details}}<div class="item-details">{{details}}</div>{{/if}}
                        </td>
                        <td class="item-quantity">{{quantity}}</td>
                        <td class="item-rate">{{formatCurrency rate}}</td>
                        {{#if ../showTax}}
                        <td class="item-rate">{{tax}}%</td>
                        {{/if}}
                        <td class="item-amount">{{formatCurrency amount}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <!-- Totals Section -->
            <div class="totals-section">
                <div class="payment-info">
                    <h3>Información de Pago</h3>
                    <div class="payment-details">
                        {{#if paymentTerms}}<strong>Términos:</strong> {{paymentTerms}}<br>{{/if}}
                        {{#if bankInfo}}
                        <strong>💳 Datos Bancarios para Pagos:</strong><br>
                        Banco: {{bankInfo.bankName}}<br>
                        Cuenta N°: {{bankInfo.accountNumber}}<br>
                        NEQUI: {{bankInfo.nequi}}<br>
                        Titular: {{bankInfo.titular}}<br>
                        NIT: {{bankInfo.taxId}}<br>
                        {{/if}}
                        {{#if paymentMethods}}
                        <div style="margin-top: 1rem;">
                            <strong>Métodos de Pago:</strong><br>
                            {{join paymentMethods ', '}}
                        </div>
                        {{/if}}
                    </div>
                </div>

                <div>
                    <table class="totals-table">
                        <tr>
                            <td>Subtotal:</td>
                            <td>{{formatCurrency subtotal}}</td>
                        </tr>
                        {{#if discount}}
                        <tr>
                            <td>Descuento {{#if discountPercent}}({{discountPercent}}%){{/if}}:</td>
                            <td>-{{formatCurrency discount}} {{currency}}</td>
                        </tr>
                        {{/if}}
                        {{#if taxAmount}}
                        <tr>
                            <td>IVA {{#if taxRate}}({{taxRate}}%){{/if}}:</td>
                            <td>{{formatCurrency taxAmount}} {{currency}}</td>
                        </tr>
                        {{/if}}
                        {{#if shippingCost}}
                        <tr>
                            <td>Gastos de Envío:</td>
                            <td>{{formatCurrency shippingCost}} {{currency}}</td>
                        </tr>
                        {{/if}}
                        <tr class="total-row">
                            <td>TOTAL:</td>
                            <td>{{formatCurrency total}}</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Notes -->
            {{#if notes}}
            <div class="notes-section">
                <h3>Notas</h3>
                <div class="notes-content">{{formatContent notes}}</div>
            </div>
            {{/if}}

            <!-- Terms and Conditions -->
            {{#if terms}}
            <div class="terms-section">
                <h3>Términos y Condiciones</h3>
                <ul class="terms-list">
                    {{#each terms}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
            </div>
            {{/if}}
        </div>

        <!-- Footer -->
        <div class="invoice-footer">
            <div class="footer-content">
                <div class="footer-company">
                    <div><strong>{{companyName}}</strong></div>
                    {{#if companyInfo.website}}<div>{{companyInfo.website}}</div>{{/if}}
                </div>
                
                <div class="footer-logo">
                    {{substring companyName 0 2}}
                </div>
                
                <div class="footer-contact">
                    {{#if companyInfo.email}}<div>{{companyInfo.email}}</div>{{/if}}
                    {{#if companyInfo.phone}}<div>{{companyInfo.phone}}</div>{{/if}}
                </div>
            </div>
            
            <div class="footer-legal">
                Factura generada el {{currentDate}}
                {{#if companyInfo.taxId}} • NIF/CIF: {{companyInfo.taxId}}{{/if}}
                {{#if metadata.branding.companyName}}
                <br>Generado con {{metadata.branding.companyName}} PDF Generator v2.0
                {{/if}}
            </div>
        </div>
    </div>
</body>
</html>
