<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        :root {
            --primary-color: #0d9488;
            /* Teal 600 */
            --secondary-color: #0f766e;
            /* Teal 700 */
            --text-dark: #1f2937;
            --text-light: #6b7280;
            --bg-light: #f0fdfa;
            /* Teal 50 */
            --border-color: #e5e7eb;
            --header-bg: #ccfbf1;
            /* Teal 100 */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            line-height: 1.5;
            color: var(--text-dark);
            background: white;
            font-size: 12px;
        }

        .page {
            max-width: 21cm;
            margin: 0 auto;
            padding: 25px;
            min-height: 29.7cm;
        }

        /* Header */
        .header {
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 24px;
            color: var(--secondary-color);
            margin-bottom: 5px;
        }

        .header h2 {
            font-size: 16px;
            color: var(--text-light);
            font-weight: 400;
        }

        .meta-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            margin-top: 20px;
            background: var(--bg-light);
            padding: 15px;
            border-radius: 8px;
            font-size: 11px;
        }

        .meta-item strong {
            display: block;
            color: var(--secondary-color);
            margin-bottom: 2px;
        }

        /* Phases */
        .phase-section {
            margin-bottom: 40px;
            page-break-inside: avoid;
        }

        .phase-title {
            background: var(--primary-color);
            color: white;
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 16px;
            margin-bottom: 15px;
            font-weight: 600;
        }

        .phase-objective {
            font-style: italic;
            color: var(--text-light);
            margin-bottom: 20px;
            padding-left: 10px;
            border-left: 3px solid var(--primary-color);
        }

        /* Tables */
        .budget-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            font-size: 11px;
        }

        .budget-table th {
            background: var(--header-bg);
            color: var(--secondary-color);
            padding: 10px;
            text-align: left;
            font-weight: 600;
            border-bottom: 1px solid var(--primary-color);
        }

        .budget-table td {
            padding: 10px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: top;
        }

        .budget-table tr:last-child td {
            border-bottom: none;
        }

        .subtotal-row td {
            background: var(--bg-light);
            font-weight: 700;
            color: var(--secondary-color);
            text-align: right;
        }

        .table-subtitle {
            font-size: 13px;
            font-weight: 600;
            color: var(--secondary-color);
            margin: 15px 0 10px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 5px;
        }

        /* Summary */
        .summary-section {
            margin-top: 50px;
            background: var(--bg-light);
            padding: 30px;
            border-radius: 12px;
            border: 1px solid var(--primary-color);
            page-break-inside: avoid;
        }

        .summary-title {
            font-size: 18px;
            color: var(--secondary-color);
            margin-bottom: 20px;
            text-align: center;
        }

        .total-project {
            font-size: 20px;
            font-weight: 700;
            text-align: center;
            color: var(--primary-color);
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px dashed var(--border-color);
        }

        /* Indicators */
        .indicators-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 30px;
        }

        .indicator-card {
            background: white;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
        }

        .indicator-title {
            font-weight: 700;
            color: var(--secondary-color);
            margin-bottom: 5px;
        }

        .footer {
            margin-top: 50px;
            text-align: center;
            font-size: 10px;
            color: var(--text-light);
            border-top: 1px solid var(--border-color);
            padding-top: 20px;
        }

        @media print {
            .page-break {
                page-break-before: always;
            }
        }
    </style>
</head>

<body>
    <div class="page">
        <div class="header">
            <h1>{{title}}</h1>
            <h2>{{subtitle}}</h2>
            <div class="meta-grid">
                <div class="meta-item"><strong>Moneda</strong>{{meta.currency}}</div>
                <div class="meta-item"><strong>Estándar</strong>{{meta.standard}}</div>
                <div class="meta-item"><strong>Horizonte</strong>{{meta.horizon}}</div>
            </div>
            <p style="margin-top: 20px; font-size: 12px; color: var(--text-light);">{{intro}}</p>
        </div>

        {{#each phases}}
        <div class="phase-section {{#if @first}}{{else}}page-break{{/if}}">
            <div class="phase-title">{{title}}</div>
            <div class="phase-objective">{{objective}}</div>

            {{#each tables}}
            {{#if subtitle}}<div class="table-subtitle">{{subtitle}}</div>{{/if}}
            <table class="budget-table">
                <thead>
                    <tr>
                        {{#if ../isExpansion}}
                        <th width="20%">Categoría</th>
                        <th width="40%">Ítem</th>
                        <th width="15%">Costo</th>
                        <th width="25%">Detalle</th>
                        {{else}}
                        <th width="25%">Ítem</th>
                        <th width="40%">Descripción</th>
                        <th width="15%">Costo</th>
                        <th width="20%">Justificación</th>
                        {{/if}}
                    </tr>
                </thead>
                <tbody>
                    {{#each rows}}
                    <tr>
                        {{#if ../../isExpansion}}
                        <td>{{category}}</td>
                        <td>{{item}}</td>
                        <td><strong>{{cost}}</strong></td>
                        <td>{{detail}}</td>
                        {{else}}
                        <td><strong>{{item}}</strong></td>
                        <td>{{desc}}</td>
                        <td><strong>{{cost}}</strong></td>
                        <td>{{justification}}</td>
                        {{/if}}
                    </tr>
                    {{/each}}
                    {{#if subtotal}}
                    <tr class="subtotal-row">
                        <td colspan="{{#if ../isExpansion}}3{{else}}2{{/if}}">Subtotal</td>
                        <td colspan="2">{{subtotal}}</td>
                    </tr>
                    {{/if}}
                </tbody>
            </table>
            {{/each}}

            {{#if total}}
            <div
                style="text-align: right; font-size: 14px; font-weight: 700; color: var(--secondary-color); margin-top: 10px;">
                TOTAL FASE: {{total}} {{#if burnRate}}<span
                    style="font-weight: 400; font-size: 12px; color: var(--text-light);">| Burn Rate:
                    {{burnRate}}</span>{{/if}}
            </div>
            {{/if}}
        </div>
        {{/each}}

        <div class="summary-section page-break">
            <div class="summary-title">Resumen Ejecutivo del Presupuesto</div>

            <table class="budget-table">
                <thead>
                    <tr>
                        <th>Fase</th>
                        <th>Tiempo</th>
                        <th>Hitos Clave</th>
                        <th>Inversión</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each summary.rows}}
                    <tr>
                        <td><strong>{{phase}}</strong></td>
                        <td>{{time}}</td>
                        <td>{{milestones}}</td>
                        <td><strong>{{investment}}</strong></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <div class="total-project">
                TOTAL PROYECTO: {{summary.totalProject}}
            </div>

            <div class="indicators-grid">
                {{#each indicators}}
                <div class="indicator-card">
                    <div class="indicator-title">{{title}}</div>
                    <div>{{desc}}</div>
                </div>
                {{/each}}
            </div>
        </div>

        <div class="footer">
            {{footer}}
        </div>
    </div>
</body>

</html>