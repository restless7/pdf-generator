<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{proposalTitle}} - Reunión Estratégica</title>
    <style>
        /* Modern Professional Design System - Meeting Plan Template */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        :root {
            --primary-emerald: #10B981;
            --primary-emerald-dark: #059669;
            --emerald-light: #D1FAE5;
            --emerald-50: #ECFDF5;
            --gray-900: #111827;
            --gray-800: #1F2937;
            --gray-700: #374151;
            --gray-600: #4B5563;
            --gray-500: #6B7280;
            --gray-400: #9CA3AF;
            --gray-300: #D1D5DB;
            --gray-100: #F3F4F6;
            --gray-50: #F9FAFB;
            --white: #FFFFFF;
            --accent-blue: #3B82F6;
            --accent-purple: #8B5CF6;
            --warning-orange: #F59E0B;
            --success-green: #10B981;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --radius-md: 8px;
            --radius-lg: 12px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.7;
            color: var(--gray-700);
            background: var(--white);
            font-size: 14px;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        .container {
            max-width: 210mm;
            margin: 0 auto;
            padding: 0;
        }
        
        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            color: var(--gray-900);
            font-weight: 600;
            line-height: 1.25;
            margin-bottom: 1rem;
        }
        
        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-emerald), var(--primary-emerald-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-align: center;
            margin-bottom: 1.5rem;
        }
        
        h2 {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--gray-900);
            margin-top: 2rem;
            margin-bottom: 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--emerald-light);
            position: relative;
            page-break-after: avoid;
        }
        
        h2::before {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 60px;
            height: 2px;
            background: linear-gradient(90deg, var(--primary-emerald), var(--primary-emerald-dark));
        }
        
        h3 {
            font-size: 1.375rem;
            font-weight: 600;
            color: var(--gray-800);
            margin-top: 1.5rem;
            margin-bottom: 1rem;
        }
        
        h4 {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--gray-700);
            margin-top: 1.25rem;
            margin-bottom: 0.75rem;
        }
        
        p {
            margin-bottom: 1.25rem;
            color: var(--gray-600);
            text-align: justify;
        }
        
        /* Lists */
        ul, ol {
            margin-bottom: 1.25rem;
            padding-left: 1.5rem;
        }
        
        li {
            margin-bottom: 0.5rem;
            color: var(--gray-600);
        }
        
        ul li::marker {
            color: var(--primary-emerald);
        }
        
        strong {
            font-weight: 600;
            color: var(--gray-800);
        }
        
        /* Page breaks */
        .page-break {
            page-break-before: always;
        }
        
        .page-break-avoid {
            page-break-inside: avoid;
        }
        
        /* Cover page */
        .cover-page {
            height: 297mm;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: linear-gradient(135deg, var(--emerald-50) 0%, var(--white) 100%);
            position: relative;
            overflow: hidden;
            padding: 3rem;
        }
        
        .cover-page::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, transparent 70%);
            animation: pulse 8s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .cover-content {
            position: relative;
            z-index: 10;
            max-width: 700px;
            padding: 3rem;
        }
        
        .cover-title {
            font-size: 3rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-emerald), var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }
        
        .cover-subtitle {
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--gray-600);
            margin-bottom: 2rem;
        }
        
        .cover-details {
            display: grid;
            gap: 1rem;
            margin-top: 2rem;
            text-align: left;
        }
        
        .cover-detail-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.8);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
        }
        
        .cover-detail-label {
            font-weight: 600;
            color: var(--gray-700);
        }
        
        .cover-detail-value {
            font-weight: 500;
            color: var(--primary-emerald-dark);
        }
        
        /* Content sections */
        .content-page {
            padding: 2rem;
            margin-top: 2rem;
        }
        
        .content-section {
            margin-bottom: 2rem;
            page-break-inside: avoid;
        }
        
        /* Highlight boxes */
        .highlight-box {
            background: linear-gradient(135deg, var(--emerald-50), rgba(16, 185, 129, 0.05));
            border-left: 4px solid var(--primary-emerald);
            padding: 1.5rem;
            margin: 1.5rem 0;
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            page-break-inside: avoid;
        }
        
        .highlight-box h4 {
            color: var(--primary-emerald-dark);
            margin-top: 0;
            margin-bottom: 1rem;
        }
        
        .highlight-box p {
            margin-bottom: 0;
        }
        
        /* Code/info boxes */
        .code-box {
            background: var(--gray-50);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-md);
            padding: 1.5rem;
            margin: 1rem 0;
            font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
            font-size: 0.9rem;
            line-height: 1.6;
            white-space: pre-line;
            page-break-inside: avoid;
            color: var(--gray-700);
        }
        
        /* Agenda items */
        .agenda-section {
            margin-bottom: 3rem;
            page-break-inside: avoid;
        }
        
        .agenda-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, var(--primary-emerald), var(--primary-emerald-dark));
            color: var(--white);
            padding: 1rem 1.5rem;
            border-radius: var(--radius-md) var(--radius-md) 0 0;
            margin-bottom: 0;
        }
        
        .agenda-header h3 {
            margin: 0;
            font-size: 1.25rem;
        }
        
        .agenda-duration {
            font-size: 0.9rem;
            opacity: 0.9;
            background: rgba(255, 255, 255, 0.2);
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
        }
        
        .agenda-items {
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-top: none;
            border-radius: 0 0 var(--radius-md) var(--radius-md);
            padding: 0;
        }
        
        .agenda-item {
            padding: 1.5rem;
            border-bottom: 1px solid var(--gray-100);
        }
        
        .agenda-item:last-child {
            border-bottom: none;
        }
        
        .agenda-item-title {
            font-weight: 600;
            color: var(--gray-800);
            margin-bottom: 0.75rem;
            font-size: 1.1rem;
        }
        
        .agenda-item-description {
            color: var(--gray-600);
            line-height: 1.6;
            white-space: pre-line;
        }
        
        /* Module cards */
        .module-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }
        
        .module-card {
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            box-shadow: var(--shadow-md);
            page-break-inside: avoid;
        }
        
        .module-card h4 {
            color: var(--primary-emerald-dark);
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }
        
        .module-requirements {
            list-style: none;
            padding-left: 0;
        }
        
        .module-requirements li {
            position: relative;
            padding-left: 1.5rem;
            margin-bottom: 0.75rem;
        }
        
        .module-requirements li::before {
            content: '▶';
            position: absolute;
            left: 0;
            color: var(--primary-emerald);
            font-size: 0.8rem;
        }
        
        /* Tips section */
        .tips-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1rem;
            margin: 2rem 0;
        }
        
        .tip-card {
            background: linear-gradient(135deg, var(--gray-50), var(--white));
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-md);
            padding: 1.25rem;
            box-shadow: var(--shadow-sm);
        }
        
        .tip-title {
            font-weight: 600;
            color: var(--primary-emerald-dark);
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }
        
        .tip-description {
            color: var(--gray-600);
            font-size: 0.9rem;
            margin: 0;
        }
        
        /* Action items */
        .action-items {
            display: grid;
            gap: 1rem;
            margin: 2rem 0;
        }
        
        .action-item {
            display: flex;
            align-items: flex-start;
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-md);
            padding: 1.25rem;
            box-shadow: var(--shadow-sm);
        }
        
        .action-number {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            background: var(--primary-emerald);
            color: var(--white);
            border-radius: 50%;
            font-weight: 600;
            font-size: 0.9rem;
            flex-shrink: 0;
            margin-right: 1rem;
        }
        
        .action-content h4 {
            margin: 0 0 0.5rem 0;
            color: var(--gray-800);
        }
        
        .action-content p {
            margin: 0;
            color: var(--gray-600);
        }
        
        /* Footer */
        .footer {
            margin-top: 4rem;
            padding: 2rem;
            background: var(--gray-50);
            border-top: 1px solid var(--gray-200);
            text-align: center;
            color: var(--gray-500);
            font-size: 0.85rem;
        }
        
        .footer-logo {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary-emerald);
            margin-bottom: 0.5rem;
        }
        
        /* Print optimizations */
        @media print {
            body {
                font-size: 12pt;
            }
            
            h1 {
                font-size: 24pt;
            }
            
            h2 {
                font-size: 18pt;
            }
            
            h3 {
                font-size: 14pt;
            }
            
            .page-break {
                page-break-before: always;
            }
            
            .page-break-avoid {
                page-break-inside: avoid;
            }
            
            .agenda-section,
            .module-card,
            .content-section {
                page-break-inside: avoid;
            }
            
            .cover-page {
                height: 100vh;
            }
            
            .module-grid {
                grid-template-columns: 1fr;
            }
            
            .tips-grid {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Cover Page -->
        <div class="cover-page page-break-avoid">
            <div class="cover-content">
                <div class="cover-title">{{proposalTitle}}</div>
                <div class="cover-subtitle">{{subtitle}}</div>
                
                <div class="cover-details">
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Participantes:</span>
                        <span class="cover-detail-value">{{partnerNames}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Alianza:</span>
                        <span class="cover-detail-value">{{proposedEntity}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Fecha del Documento:</span>
                        <span class="cover-detail-value">{{formatDate proposalDate}}</span>
                    </div>
                    <div class="cover-detail-item">
                        <span class="cover-detail-label">Estado:</span>
                        <span class="cover-detail-value">{{documentStatus}}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Executive Summary -->
        <div class="page-break">
            <div class="content-page">
                <h2>Resumen Ejecutivo</h2>
                <div class="content-section">
                    <p>{{formatContent executiveSummary}}</p>
                    
                    {{#if proposedStructure}}
                    <div class="highlight-box">
                        <h4>Estructura de la Reunión</h4>
                        <div class="code-box">{{formatContent proposedStructure}}</div>
                    </div>
                    {{/if}}
                    
                    {{#if entityDetails}}
                    <div class="highlight-box">
                        <h4>Enfoque Estratégico</h4>
                        <p>{{formatContent entityDetails}}</p>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>

        <!-- Meeting Goal -->
        {{#if meetingGoal}}
        <h2>{{meetingGoal.title}}</h2>
        <div class="content-section">
            <p>{{meetingGoal.description}}</p>
            
            <h4>Resultados Esperados:</h4>
            <ul>
                {{#each meetingGoal.keyOutcomes}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>
        {{/if}}

        <!-- Agenda -->
        {{#if agendaItems}}
        <h2>Agenda Detallada</h2>
        
        {{#each agendaItems}}
        <div class="agenda-section">
            <div class="agenda-header">
                <h3>{{section}}</h3>
                <div class="agenda-duration">{{duration}}</div>
            </div>
            <div class="agenda-items">
                {{#each items}}
                <div class="agenda-item">
                    <div class="agenda-item-title">{{title}}</div>
                    <div class="agenda-item-description">{{description}}</div>
                </div>
                {{/each}}
            </div>
        </div>
        {{/each}}
        {{/if}}

        <!-- APEX Modules Requirements -->
        {{#if apexModules}}
        <div class="page-break">
            <h2>Requerimientos de Módulos APEX AI</h2>
            <div class="content-section">
                <p>{{apexModules.overview}}</p>
                
                <div class="module-grid">
                    {{#each apexModules.modules}}
                    <div class="module-card">
                        <h4>{{name}}</h4>
                        <ul class="module-requirements">
                            {{#each dataRequirements}}
                            <li>{{this}}</li>
                            {{/each}}
                        </ul>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>
        {{/if}}

        <!-- Data Architecture -->
        {{#if dataArchitecture}}
        <h2>Arquitectura de Datos - Principios y Componentes</h2>
        
        <h3>Principios de Diseño</h3>
        <div class="content-section">
            {{#each dataArchitecture.principles}}
            <div class="highlight-box">
                <h4>{{principle}}</h4>
                <p>{{description}}</p>
            </div>
            {{/each}}
        </div>
        
        <h3>Componentes Clave</h3>
        <div class="content-section">
            {{#each dataArchitecture.components}}
            <h4>{{component}}</h4>
            <p>{{description}}</p>
            {{/each}}
        </div>
        {{/if}}

        <!-- Data Sanitization -->
        {{#if dataSanitization}}
        <h2>Estrategia de Sanación de Datos</h2>
        <div class="content-section">
            <p>{{dataSanitization.approach}}</p>
            
            <h4>Preguntas Clave:</h4>
            {{#each dataSanitization.priorities}}
            <div class="highlight-box">
                <h4>{{priority}}</h4>
                <p>{{question}}</p>
            </div>
            {{/each}}
        </div>
        {{/if}}

        <!-- Technical Considerations -->
        {{#if technicalConsiderations}}
        <h2>Consideraciones Técnicas</h2>
        <div class="content-section">
            {{#each technicalConsiderations}}
            <h4>{{consideration}}</h4>
            <p>{{description}}</p>
            {{/each}}
        </div>
        {{/if}}

        <!-- Meeting Tips -->
        {{#if meetingTips}}
        <h2>{{meetingTips.title}}</h2>
        <div class="content-section">
            <div class="tips-grid">
                {{#each meetingTips.tips}}
                <div class="tip-card">
                    <div class="tip-title">{{tip}}</div>
                    <div class="tip-description">{{description}}</div>
                </div>
                {{/each}}
            </div>
        </div>
        {{/if}}

        <!-- Next Steps -->
        {{#if nextSteps}}
        <h2>Próximos Pasos</h2>
        
        <h3>{{nextSteps.documentation.title}}</h3>
        <div class="content-section">
            <p>{{nextSteps.documentation.description}}</p>
            <div class="highlight-box">
                <h4>Pregunta Clave</h4>
                <p>{{nextSteps.documentation.responsibilities}}</p>
            </div>
        </div>
        
        <h3>{{nextSteps.meetings.title}}</h3>
        <div class="content-section">
            <p>{{nextSteps.meetings.description}}</p>
            <div class="code-box">{{nextSteps.meetings.tasks}}</div>
        </div>
        
        <h3>{{nextSteps.resources.title}}</h3>
        <div class="content-section">
            <p>{{nextSteps.resources.description}}</p>
            <p><strong>Stakeholders potenciales:</strong> {{nextSteps.resources.stakeholders}}</p>
            <div class="highlight-box">
                <h4>Acceso Requerido</h4>
                <p>{{nextSteps.resources.access}}</p>
            </div>
        </div>
        {{/if}}

        <!-- Conclusion & Action Items -->
        {{#if conclusion}}
        <div class="page-break">
            <h2>Conclusión y Plan de Acción</h2>
            <div class="content-section">
                <p>{{formatContent conclusion.summary}}</p>
                
                {{#if conclusion.actionItems}}
                <h4>Elementos de Acción Inmediata</h4>
                <div class="action-items">
                    {{#each conclusion.actionItems}}
                    <div class="action-item">
                        <div class="action-number">{{@index}}</div>
                        <div class="action-content">
                            <h4>{{action}}</h4>
                            <p>{{description}}</p>
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
                
                {{#if conclusion.successCriteria}}
                <h4>Criterios de Éxito</h4>
                <ul>
                    {{#each conclusion.successCriteria}}
                    <li><strong>{{criterion}}:</strong> {{description}}</li>
                    {{/each}}
                </ul>
                {{/if}}
            </div>
        </div>
        {{/if}}

        <!-- Footer -->
        <div class="footer">
            <div class="footer-logo">{{branding}}</div>
            <p>{{contactInfo.name}} • {{contactInfo.title}}</p>
            <p>{{contactInfo.phone}} • {{contactInfo.email}}</p>
            <p>{{contactInfo.website}}</p>
        </div>
    </div>
</body>
</html>
