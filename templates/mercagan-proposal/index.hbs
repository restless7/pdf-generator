<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{proposalTitle}}</title>
    <style>
        :root {
            --primary: #06574a; /* Verde Mercagán */
            --accent: #f97316;  /* Naranja Mercagán */
            --bg-light: #f8fafc;
            --text-dark: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --white: #ffffff;
            --success: #10b981;
            --danger: #ef4444;
        }

        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Outfit', sans-serif; background: #f1f5f9; color: var(--text-dark); line-height: 1.5; font-size: 13px; }
        
        /* Document Layout */
        .page { width: 210mm; margin: 0 auto; background: var(--white); min-height: 296mm; position: relative; overflow: hidden; page-break-after: always; }
        .content-padding { padding: 20mm; }

        /* Typography */
        h1 { font-size: 42px; line-height: 1.1; font-weight: 700; color: var(--primary); }
        h2 { font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: 20px; border-bottom: 2px solid var(--accent); display: inline-block; padding-bottom: 5px; }
        h3 { font-size: 16px; font-weight: 600; color: var(--primary); margin-bottom: 10px; }
        p { margin-bottom: 15px; color: var(--text-dark); }
        .text-accent { color: var(--accent); font-weight: 600; }

        /* Components */
        .card { background: var(--bg-light); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 20px; page-break-inside: avoid; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; page-break-inside: avoid; }
        .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; page-break-inside: avoid; }
        
        .badge { padding: 4px 10px; border-radius: 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .badge-danger { background: #fee2e2; color: #b91c1c; }
        .badge-warning { background: #ffedd5; color: #9a3412; }
        .badge-success { background: #dcfce7; color: #15803d; }

        /* Tables */
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th { background: var(--primary); color: white; text-align: left; padding: 12px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
        td { padding: 12px; border-bottom: 1px solid var(--border); font-size: 12px; vertical-align: top; }
        tr:nth-child(even) { background: #fdfdfd; }

        /* Flowchart Visuals */
        .flow-container { display: flex; align-items: center; justify-content: space-between; margin: 30px 0; }
        .flow-box { width: 35mm; padding: 10px; background: white; border: 2px solid var(--primary); border-radius: 8px; text-align: center; font-weight: 600; font-size: 11px; z-index: 10; }
        .flow-arrow { flex: 1; height: 2px; background: var(--border); position: relative; }
        .flow-arrow::after { content: "→"; position: absolute; right: -5px; top: -9px; color: var(--border); font-weight: bold; font-size: 20px; }
        .flow-arrow.accent { background: var(--accent); }
        .flow-arrow.accent::after { color: var(--accent); }

        /* Charts */
        .bar-chart { margin: 20px 0; }
        .bar-row { margin-bottom: 15px; }
        .bar-label { display: flex; justify-content: space-between; margin-bottom: 5px; font-weight: 600; }
        .bar-rail { height: 12px; background: #e2e8f0; border-radius: 6px; overflow: hidden; }
        .bar-fill { height: 100%; background: var(--primary); }
        .bar-fill.accent { background: var(--accent); }

        /* ROI Chart Specialized Styles */
        .roi-chart-container { position: relative; height: 70mm; margin-top: 30px; border-left: 2px solid var(--text-dark); border-bottom: 2px solid var(--text-dark); background: linear-gradient(to top, #fff 0%, #fff 100%); }
        .roi-y-axis { position: absolute; left: -45px; top: 0; bottom: 0; display: flex; flex-direction: column-reverse; justify-content: space-between; font-size: 9px; color: var(--text-muted); padding-right: 5px; text-align: right; width: 40px; }
        .roi-grid-line { position: absolute; left: 0; right: 0; height: 1px; background: rgba(0,0,0,0.05); }
        .roi-legend { display: flex; justify-content: center; gap: 20px; margin-top: 25px; font-size: 11px; }
        .legend-item { display: flex; align-items: center; gap: 6px; }
        .legend-dot { width: 10px; height: 10px; border-radius: 2px; }

        /* Timeline */
        .timeline { position: relative; margin-top: 30px; }
        .timeline::before { content: ""; position: absolute; left: 20px; top: 0; bottom: 0; width: 4px; background: var(--bg-light); }
        .timeline-item { position: relative; padding-left: 60px; margin-bottom: 30px; }
        .timeline-bubble { position: absolute; left: 0; top: 0; width: 44px; height: 44px; background: var(--primary); border: 4px solid white; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; }

        /* Header/Footer */
        .page-header { border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
        .page-footer { position: absolute; bottom: 10mm; left: 15mm; right: 15mm; border-top: 1px solid var(--border); padding-top: 10px; display: flex; justify-content: space-between; font-size: 10px; color: var(--text-muted); }

        @media print {
            body { background: white; }
            .page { box-shadow: none; margin: 0; }
        }
    </style>
</head>
<body>

    <!-- PAGE 1: PORTADA -->
    <div class="page">
        <div style="height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; background: linear-gradient(135deg, #facc15 0%, #fbbf24 100%); padding-top: 20mm;">
            <div style="text-align: center; max-width: 90%;">
                <div style="margin-bottom: 30px; border-bottom: 5px solid var(--accent); display: inline-block; padding-bottom: 10px;">
                    <h1 style="margin: 0; text-transform: uppercase; letter-spacing: -1px; color: var(--primary); line-height: 1.1;">{{proposalTitle}}</h1>
                </div>
                <div style="font-size: 22px; color: var(--text-dark); font-weight: 500; margin-bottom: 40px; max-width: 80%; margin-left: auto; margin-right: auto;">{{subtitle}}</div>
                
                <div style="width: 110mm; height: 110mm; background: #fff; border: 2px dashed var(--border); margin: 0 auto 50px; border-radius: 20px; display: flex; align-items: center; justify-content: center; color: var(--text-muted); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);">
                    LOGO MERCAGÁN
                </div>
                
                <div style="font-weight: 700; font-size: 16px; color: var(--primary); text-transform: uppercase; letter-spacing: 2px;">Propuesta Estratégica de Transformación Digital</div>
                <div style="color: var(--text-muted); margin-top: 5px; font-weight: 600;">Bucaramanga, 2026</div>
            </div>
        </div>
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 8mm; background: var(--accent); opacity: 0.9;"></div>
    </div>

    <!-- PAGE 2: RESUMEN EJECUTIVO -->
    <div class="page">
        <div class="content-padding">
            <div class="page-header">
                <div style="color: var(--primary); font-weight: 700;">APEX AI SOLUTIONS × MERCAGÁN</div>
                <div style="color: var(--text-muted);">Página 02</div>
            </div>
            
            <h2>1. Resumen Ejecutivo</h2>
            <div class="lead" style="font-size: 16px; line-height: 1.6; margin-bottom: 30px;">
                Esta propuesta detalla el desarrollo de <strong>Mercagán Core 360</strong>, un sistema unificado diseñado específicamente para eliminar la fragmentación operativa actual y sentar las bases de una escalabilidad sin límites.
            </div>

            <div class="grid-2">
                <div class="card" style="border-left: 4px solid var(--danger);">
                    <h3>El Desafío</h3>
                    <p>{{executiveSummary.problem}}</p>
                </div>
                <div class="card" style="border-left: 4px solid var(--success);">
                    <h3>La Solución</h3>
                    <p>{{executiveSummary.solution}}</p>
                </div>
            </div>

            <div class="card" style="background: var(--primary); color: white;">
                <div class="grid-3" style="text-align: center;">
                    <div>
                        <div style="font-size: 24px; font-weight: 700; color: var(--accent);">3.5 - 4.5h</div>
                        <div style="font-size: 11px; opacity: 0.9;">Ahorro de Tiempo Diario</div>
                    </div>
                    <div>
                        <div style="font-size: 24px; font-weight: 700; color: var(--accent);">< 8 min</div>
                        <div style="font-size: 11px; opacity: 0.9;">Cierre de Caja</div>
                    </div>
                    <div>
                        <div style="font-size: 24px; font-weight: 700; color: var(--accent);">6 - 8 meses</div>
                        <div style="font-size: 11px; opacity: 0.9;">Retorno de Inversión</div>
                    </div>
                </div>
            </div>

            <h3 style="margin-top: 30px;">Nuestro Compromiso de Partnership</h3>
            <p>{{executiveSummary.partnership}}</p>
            <p>A diferencia de los proveedores tradicionales, entregamos la <strong>propiedad del código</strong> y un soporte directo que evoluciona con el restaurante, garantizando que el software nunca sea una limitación, sino una ventaja competitiva.</p>
        </div>
        <div class="page-footer">
            <div>{{proposalTitle}} - Confidencial</div>
            <div>© 2026 APEX AI Solutions</div>
        </div>
    </div>

    <!-- PAGE 3: SITUACIÓN ACTUAL -->
    <div class="page">
        <div class="content-padding">
            <h2>2. Situación Actual: Fragmentación y Riesgos</h2>
            <p>Tras el análisis de la operación en Mercagán, identificamos un ecosistema de software desconectado que depende críticamente de la intervención humana y la re-digitación de datos.</p>

            <div class="grid-3">
                {{#each currentSituation.systems}}
                <div class="card">
                    <div style="font-weight: 700; color: var(--accent); margin-bottom: 5px;">{{name}}</div>
                    <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">{{type}}</div>
                    <p style="font-size: 11px; margin: 0;">{{desc}}</p>
                </div>
                {{/each}}
            </div>

            <h3 style="margin-top: 20px;">Flujo de Información Actual (Triple Digitación)</h3>
            <div class="flow-container">
                <div class="flow-box">Website / WhatsApp</div>
                <div class="flow-arrow" style="flex: 0.5;"></div>
                <div class="flow-box" style="background: #fee2e2; border-color: var(--danger);">Operador Humano</div>
                <div class="flow-arrow" style="flex: 0.5;"></div>
                <div class="flow-box">Software KGM</div>
                <div class="flow-arrow" style="flex: 0.5;"></div>
                <div class="flow-box">Excels de Cierre</div>
            </div>
            <p style="text-align: center; color: var(--danger); font-size: 11px; font-weight: 600;">Este flujo genera un riesgo de error del 12-15% en la transcripción de datos financieros.</p>

            <h3 style="margin-top: 30px;">Diagnóstico de Problemas Identificados</h3>
            <table>
                <thead>
                    <tr>
                        <th style="width: 30%;">Problema</th>
                        <th style="width: 50%;">Impacto Operativo</th>
                        <th>Prioridad</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each identifiedProblems}}
                    <tr>
                        <td><strong>{{problem}}</strong></td>
                        <td>{{impact}}</td>
                        <td><span class="badge {{#if (eq priority "Crítica")}}badge-danger{{else}}badge-warning{{/if}}">{{priority}}</span></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        <div class="page-footer">
            <div>Página 03</div>
            <div>Análisis de Situación Actual</div>
        </div>
    </div>

    <!-- PAGE 4: SOLUCIÓN PROPUESTA -->
    <div class="page">
        <div class="content-padding">
            <h2>3. Solución: Mercagán Core 360</h2>
            <p>{{proposedSolution.concept}}</p>

            <div class="card" style="border-top: 8px solid var(--primary);">
                <h3>Alianza Estratégica: Trabajo en Equipo</h3>
                <p style="font-size: 12px; margin-bottom: 0;">{{collaboration.desc}}</p>
            </div>
            
            <div class="card" style="border-top: 8px solid var(--accent); margin-top: 20px;">
                <h3>Ventajas del Desarrollo 100% a Medida</h3>
                <div class="grid-2">
                    <ul style="padding-left: 15px; font-size: 11px;">
                        <li style="margin-bottom: 8px;">Un sistema único (sin integraciones frágiles).</li>
                        <li style="margin-bottom: 8px;">Cero licencias mensuales a terceros.</li>
                        <li style="margin-bottom: 8px;">Propiedad total del código fuente.</li>
                    </ul>
                    <ul style="padding-left: 15px; font-size: 11px;">
                        <li style="margin-bottom: 8px;">Flujos adaptados a San Pio y Domicilios.</li>
                        <li style="margin-bottom: 8px;">Soporte directo con el desarrollador.</li>
                        <li style="margin-bottom: 8px;">Evolución según el crecimiento del negocio.</li>
                    </ul>
                </div>
            </div>

            <h3 style="margin-top:25px;">Stack Tecnológico de Vanguardia (Arquitectura 2026)</h3>
            <p style="font-size: 11px; color: var(--text-muted);">Utilizamos tecnologías de nivel industrial para garantizar velocidad, seguridad y disponibilidad total.</p>
            <table>
                <thead>
                    <tr>
                        <th>Capa</th>
                        <th>Tecnología</th>
                        <th>Propósito / Justificación</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each proposedSolution.techStack}}
                    <tr>
                        <td><span style="font-weight: 700; color: var(--primary);">{{layer}}</span></td>
                        <td><span class="text-accent">{{tech}}</span></td>
                        <td>{{desc}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <h3 style="margin-top: 20px;">Flujo Optimizado Core 360</h3>
            <div class="flow-container">
                <div class="flow-box" style="border-color: var(--accent);">Website / POS Móvil</div>
                <div class="flow-arrow accent"></div>
                <div class="flow-box" style="background: var(--primary); color: white; border-color: var(--accent);">SISTEMA CORE 360</div>
                <div class="flow-arrow accent"></div>
                <div class="flow-box" style="border-color: var(--accent);">Facturación DIAN / Contabilidad</div>
            </div>
        </div>
        <div class="page-footer">
            <div>Página 04</div>
            <div>Solución Técnica y Arquitectura</div>
        </div>
    </div>

    <!-- PAGE 5: MÓDULOS -->
    <div class="page">
        <div class="content-padding">
            <h2>4. Ecosistema de Módulos Incluidos</h2>
            <p>Mercagán Core 360 unifica todas las áreas críticas del restaurante en una sola interfaz intuitiva y potente.</p>

            <div class="grid-3" style="margin-top: 15px;">
                {{#each modules}}
                <div class="card" style="padding: 12px; min-height: 28mm; margin-bottom: 10px;">
                    <div style="font-weight: 700; color: var(--primary); margin-bottom: 4px; display: flex; align-items:center;">
                        <span style="display:inline-block; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; margin-right: 8px;"></span>
                        {{title}}
                    </div>
                    <p style="font-size: 10px; margin: 0; line-height: 1.3;">{{desc}}</p>
                </div>
                {{/each}}
            </div>

            <div class="card" style="margin-top: 30px; background: #fff7ed; border-color: #fdba74;">
                <h3 style="color: #9a3412;">● Enfoque Especial: San Pio y Domicilios</h3>
                <p style="font-size: 11px;">Entendemos que los vouchers de tarjetas en el punto San Pio y la re-digitación de domicilios web son sus mayores dolores operativos. Core 360 automatiza la conciliación de estos pagos y sincroniza los pedidos web al instante con las pantallas de cocina.</p>
            </div>
        </div>
        <div class="page-footer">
            <div>Página 05</div>
            <div>Funcionalidades del Sistema</div>
        </div>
    </div>

    <!-- PAGE 6: MÉTRICAS Y ROI -->
    <div class="page">
        <div class="content-padding">
            <h2>5. Beneficios y Métricas de Impacto</h2>
            
            <div class="grid-2">
                <div class="card">
                    <h3>Comparativa de Cierre de Caja</h3>
                    <div class="bar-chart">
                        {{#each benefitsMetrics.charts.timeComparison}}
                        <div class="bar-row">
                            <div class="bar-label">
                                <span>{{label}}</span>
                                <span>{{value}} min</span>
                            </div>
                            <div class="bar-rail">
                                <div class="bar-fill {{#if @index}}accent{{/if}}" style="width: {{#if @index}}10%{{else}}100%{{/if}};"></div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    <p style="font-size: 11px; color: var(--text-muted);">Hoy Mercagán pierde 15 horas a la semana solo en cierres de caja manuales.</p>
                </div>

                <div class="card" style="border-top: 5px solid var(--success);">
                    <h3>Eficiencia Operativa</h3>
                    <ul style="padding-left: 20px;">
                        <li style="margin-bottom: 10px;"><strong>Reducción de errores:</strong> {{benefitsMetrics.errorReduction}}</li>
                        <li style="margin-bottom: 10px;"><strong>Ahorro administrativo:</strong> {{benefitsMetrics.timeSavings}}</li>
                        <li><strong>Visibilidad Gerencial:</strong> 100% en tiempo real</li>
                    </ul>
                </div>
            </div>

            <h3 style="margin-top: 40px;">Proyección de Recuperación de Inversión (ROI)</h3>
            <div class="card" style="padding-left: 50px; padding-top: 30px; padding-bottom: 40px; background: white; border: none;">
                <div class="roi-chart-container">
                    <!-- Y Axis Labels -->
                    <div class="roi-y-axis">
                        {{#each benefitsMetrics.charts.roiProjection.yAxis}}
                        <span>{{this}}</span>
                        {{/each}}
                    </div>
                    
                    <!-- Grid Lines -->
                    <div class="roi-grid-line" style="bottom: 25%;"></div>
                    <div class="roi-grid-line" style="bottom: 50%;"></div>
                    <div class="roi-grid-line" style="bottom: 75%;"></div>
                    <div class="roi-grid-line" style="top: 0;"></div>

                    <!-- ROI Lines -->
                    <!-- Inversión (Fixed Line slightly tilted) -->
                    <div style="position: absolute; left: 0; bottom: 0; width: 100%; height: 2px; background: var(--primary); transform: rotate(-18deg); transform-origin: left bottom; z-index: 2; opacity: 0.8;"></div>
                    <!-- Retorno (Line that overtakes investment at month 6) -->
                    <div style="position: absolute; left: 0; bottom: 0; width: 100%; height: 2px; background: var(--accent); transform: rotate(-35deg); transform-origin: left bottom; z-index: 3;"></div>
                    
                    <!-- Data Point Callouts -->
                    <div style="position: absolute; left: 50%; bottom: 65%; transform: translate(-50%, 0); background: var(--primary); color: white; border-radius: 4px; padding: 4px 8px; font-size: 9px; font-weight: 700; z-index: 10;">Punto de Equilibrio (Breakeven)</div>
                    <div style="position: absolute; left: 50%; bottom: 15%; width: 2px; height: 50%; background: var(--border); border-left: 1px dashed var(--text-muted); z-index: 1;"></div>
                    
                    <!-- X Axis Labels -->
                    <div style="position: absolute; left: 0; bottom: -25px; width: 100%; display: flex; justify-content: space-between; font-size: 10px; color: var(--text-dark); font-weight: 600;">
                        <span>{{benefitsMetrics.charts.roiProjection.xAxis.[0]}}</span>
                        <span style="color: var(--primary);">{{benefitsMetrics.charts.roiProjection.xAxis.[1]}}</span>
                        <span>{{benefitsMetrics.charts.roiProjection.xAxis.[2]}}</span>
                    </div>
                </div>

                <div class="roi-legend">
                    {{#each benefitsMetrics.charts.roiProjection.legend}}
                    <div class="legend-item">
                        <div class="legend-dot" style="background: {{this.color}};"></div>
                        <span>{{this.label}}</span>
                    </div>
                    {{/each}}
                </div>
            </div>
            <p style="margin-top: 20px; font-style: italic; text-align: center; font-size: 11px;">"La inversión en tecnología a medida deja de ser un gasto y se convierte en una máquina de ahorro operativo desde el primer día."</p>
        </div>
        <div class="page-footer">
            <div>Página 06</div>
            <div>Retorno de Inversión</div>
        </div>
    </div>

    <!-- PAGE 7: INVERSIÓN Y FASES -->
    <div class="page">
        <div class="content-padding">
            <h2>6. Inversión y Cronograma de Trabajo</h2>
            
            <table>
                <thead>
                    <tr>
                        <th>Concepto de Inversión</th>
                        <th>Modalidad</th>
                        <th style="text-align: right;">Valor Estimado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Desarrollo del Sistema Core 360</strong><br/><small>Unificación, integraciones, POS Móvil y Facturación.</small></td>
                        <td>Pago Único</td>
                        <td style="text-align: right; font-weight: 700;">{{pricing.development}}</td>
                    </tr>
                    <tr>
                        <td><strong>Hardware Recomendado</strong><br/><small>Tablets industriales, impresoras térmicas y KDS Display.</small></td>
                        <td>Inversión Inicial</td>
                        <td style="text-align: right;">{{pricing.hardware}}</td>
                    </tr>
                    <tr>
                        <td><strong>Plan de Soporte y Evolución</strong><br/><small>Soporte 24/7, updates DIAN y mantenimiento preventivo.</small></td>
                        <td>Mensual</td>
                        <td style="text-align: right;">{{pricing.support}}</td>
                    </tr>
                </tbody>
            </table>

            <h3 style="margin-top: 20px;">Opciones y Planes de Pago</h3>
            <div class="grid-3" style="margin-top: 10px;">
                {{#each paymentPlans}}
                <div class="card" style="padding: 15px; border-top: 3px solid var(--accent); margin-bottom: 10px;">
                    <div style="font-weight: 700; color: var(--primary); margin-bottom: 5px;">{{option}}</div>
                    <p style="font-size: 10px; margin: 0;">{{desc}}</p>
                </div>
                {{/each}}
            </div>

            <h3 style="margin-top: 30px;">Fases de Implementación (10 - 12 Semanas)</h3>
            <div class="timeline">
                {{#each implementationPhases}}
                <div class="timeline-item">
                    <div class="timeline-bubble">{{#if (eq @index 0)}}1{{/if}}{{#if (eq @index 1)}}2{{/if}}{{#if (eq @index 2)}}3{{/if}}{{#if (eq @index 3)}}4{{/if}}</div>
                    <div style="font-weight: 700; color: var(--primary);">{{phase}} <span style="font-weight: 400; color: var(--accent); margin-left:10px;">{{duration}}</span></div>
                    <p style="font-size: 11px; margin-top: 5px;">{{goal}}</p>
                </div>
                {{/each}}
            </div>
        </div>
        <div class="page-footer">
            <div>Página 07</div>
            <div>Inversión y Tiempos</div>
        </div>
    </div>

    <!-- PAGE 8: CIERRE Y CTA -->
    <div class="page">
        <div class="content-padding" style="height: 100%; display: flex; flex-direction: column;">
            <h2>7. Relación a Largo Plazo y Próximos Pasos</h2>
