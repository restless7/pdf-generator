class ReporteAvaluoGenerator:
    def __init__(self, inmueble_id: int):
        self.inmueble = self.get_inmueble_data(inmueble_id)
        self.prediccion = self.get_prediccion_actual(inmueble_id)
        self.comparables = self.get_comparables(inmueble_id)
        
    def generar_reporte_completo(self) -> str:
        template = Template('reporte_avaluo.html')
        context = {
            'inmueble': self.inmueble,
            'prediccion': self.prediccion,
            'comparables': self.comparables,
            'graficas': self.generar_graficas(),
            'mapa': self.generar_mapa(),
            'fecha_generacion': datetime.now(),
            'modelo_version': self.get_modelo_version()
        }
        html_content = template.render(context)
        return self.convert_to_pdf(html_content)
                                </div>
                            </div>
